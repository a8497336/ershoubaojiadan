/* 遮罩层 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: overlayFadeIn 0.25s ease;
}

.popup-overlay.fullscreen {
  background: rgba(0, 0, 0, 0.9);
}

.popup-overlay.local {
  background: rgba(0, 0, 0, 0.6);
}

/* 弹窗主体 */
.popup-box {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  background: #fff;
  animation: boxZoomIn 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
}

.popup-box.local-box {
  width: 600rpx;
}

.popup-box.fullscreen-box {
  width: 680rpx;
}

/* 图片容器 */
.image-wrap {
  position: relative;
  width: 100%;
}

.popup-swiper {
  width: 100%;
}

.popup-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 标题栏：叠加在图片顶部，带渐变背景 */
.title-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 28rpx 24rpx 40rpx;
  z-index: 2;
}

.title-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 100%);
}

.title-text {
  position: relative;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 图片数量指示器 */
.image-count {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  z-index: 2;
}

/* 底部操作区 */
.action-bar {
  padding: 28rpx 32rpx 32rpx;
  background: #fff;
}

.action-btn {
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  letter-spacing: 2rpx;
}

.action-btn:active {
  opacity: 0.85;
}

/* 关闭按钮：弹窗外部下方圆形 */
.close-circle {
  width: 64rpx;
  height: 64rpx;
  margin-top: 40rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.close-circle:active {
  background: rgba(255, 255, 255, 0.1);
}

.close-line {
  position: absolute;
  width: 28rpx;
  height: 2rpx;
  background: #fff;
}

.close-line-1 {
  transform: rotate(45deg);
}

.close-line-2 {
  transform: rotate(-45deg);
}

/* 动画 */
@keyframes overlayFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes boxZoomIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
