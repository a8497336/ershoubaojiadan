@import '/styles/design-tokens.wxss';

.skeleton {
  padding: var(--space-3);
}

.skeleton-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--color-border);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
}

.skeleton-line {
  height: 28rpx;
  background: var(--color-border);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-2);
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-line.title {
  height: 40rpx;
  width: 80%;
  margin-bottom: var(--space-3);
}

.skeleton-card {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.skeleton-image {
  width: 100%;
  height: 200rpx;
  background: var(--color-border);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-3);
}

.skeleton-image.large {
  height: 400rpx;
}

.skeleton-card-content {
  padding: 0 var(--space-1);
}

.skeleton-detail {
  padding: var(--space-3);
}

/* 动画效果 */
.skeleton.animate .skeleton-avatar,
.skeleton.animate .skeleton-line,
.skeleton.animate .skeleton-image {
  background: linear-gradient(90deg, var(--color-border) 25%, #f0f0f0 50%, var(--color-border) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
