.page-container {
  min-height: 100vh;
  background: var(--color-background);
  padding: 24rpx;
}

.form-card {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  background: var(--color-background);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 240rpx;
  background: var(--color-background);
  border-radius: var(--radius-md);
  padding: 24rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.form-input {
  height: 80rpx;
  background: var(--color-background);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.submit-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  margin-bottom: 32rpx;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.contact-section {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
}

.contact-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.contact-item {
  padding: 20rpx 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  border-bottom: 1rpx solid var(--color-border);
}

.contact-item:last-child {
  border-bottom: none;
}
