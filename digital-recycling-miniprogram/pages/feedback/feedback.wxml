<view class="page-container">
  <view class="form-card">
    <view class="form-item">
      <view class="form-label">反馈类型</view>
      <picker mode="selector" range="{{typeList}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{typeList[typeIndex]}} ▾</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">反馈内容</view>
      <textarea
        class="form-textarea"
        value="{{content}}"
        placeholder="请详细描述您的问题或建议..."
        maxlength="500"
        bindinput="onContentInput"
      />
      <view class="char-count">{{content.length}}/500</view>
    </view>

    <view class="form-item">
      <view class="form-label">联系方式（选填）</view>
      <input
        class="form-input"
        value="{{contact}}"
        placeholder="手机号/微信号"
        bindinput="onContactInput"
      />
    </view>
  </view>

  <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="handleSubmit">
    {{submitting ? '提交中...' : '提交反馈'}}
  </view>

  <view class="contact-section">
    <view class="contact-title">其他联系方式</view>
    <view class="contact-item" bindtap="callPhone">
      <text>📞 客服电话：16618180111</text>
    </view>
    <view class="contact-item" bindtap="copyWechat">
      <text>💬 微信号：16618180111</text>
    </view>
  </view>
</view>
