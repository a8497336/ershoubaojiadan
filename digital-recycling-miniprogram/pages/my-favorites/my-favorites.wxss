@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.list-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.fav-item { display: flex; background: var(--color-background-white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
.fav-item:active { background: var(--card-active-bg); }
.fav-img { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.fav-img-placeholder { width: 160rpx; height: 160rpx; flex-shrink: 0; background: var(--skeleton-base); display: flex; align-items: center; justify-content: center; }
.fav-d-icon { width: 64rpx; height: 64rpx; opacity: 0.3; }
.fav-info { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.fav-name { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: var(--font-weight-medium); display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.fav-bottom { display: flex; justify-content: space-between; align-items: center; }
.fav-price { font-size: var(--font-size-md); color: var(--color-primary); font-weight: var(--font-weight-semibold); }
.fav-date { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
.empty-wrap { padding: 80rpx 0; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
