<view class="page-container">
  <!-- 骨架屏：仅首次无数据时展示 -->
  <view wx:if="{{loading && list.length === 0}}"><loading-skeleton type="list" rowCount="4" /></view>

  <!-- 网络错误 -->
  <view wx:if="{{networkError && !loading && list.length === 0}}" class="error-state" bindtap="loadFirstPage">
    <image class="error-img" src="/images/icons/empty.svg" mode="aspectFit" />
    <text class="error-title">网络连接失败</text>
    <text class="error-desc">点击重新加载</text>
  </view>

  <!-- 列表：有数据就展示，不随 loading 状态隐藏 -->
  <view wx:if="{{list.length > 0}}" class="list-wrap">
    <view class="fav-item" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-index="{{index}}">
      <view class="fav-brand-icon {{item.bg_color || 'bg-apple'}}" style="{{item.icon_style}}">
        <text>{{item.icon_text || item.brand_name[0] || '品'}}</text>
      </view>
      <view class="fav-info">
        <text class="fav-name">{{item.brand_name || '品牌'}}</text>
        <text class="fav-category">{{item.category_name || ''}}</text>
      </view>
      <view class="fav-remove" catchtap="onRemoveFavorite" data-index="{{index}}">
        <text class="remove-icon">×</text>
      </view>
    </view>
    <view wx:if="{{loading}}" class="no-more">加载中...</view>
    <view wx:elif="{{!hasMore}}" class="no-more">— 已经到底了 —</view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading && !networkError && list.length === 0}}" class="empty-wrap">
    <empty-state title="暂无收藏" desc="去报价单页面收藏喜欢的品牌报价吧" />
  </view>
</view>
