<view class="page-container">
  <view wx:if="{{loading && list.length === 0}}"><loading-skeleton type="list" rowCount="4" /></view>
  <view wx:if="{{networkError && !loading}}" class="error-state" bindtap="init">
    <image class="error-img" src="/images/icons/empty.svg" mode="aspectFit" />
    <text class="error-title">网络连接失败</text><text class="error-desc">点击重新加载</text>
  </view>
  <block wx:if="{{!loading && !networkError}}">
    <view wx:if="{{list.length > 0}}" class="list-wrap">
      <view class="fav-item animate-slide-up" wx:for="{{list}}" wx:key="id" bindtap="onItemTap" data-index="{{index}}">
        <image wx:if="{{item.image || item.cover}}" class="fav-img" src="{{item.image || item.cover}}" mode="aspectFill" />
        <view wx:else class="fav-img-placeholder"><image src="/images/icons/mall.svg" mode="aspectFit" class="fav-d-icon"/></view>
        <view class="fav-info">
          <text class="fav-name">{{item.name || item.title || '商品'}}</text>
          <view class="fav-bottom"><text class="fav-price">¥{{item.price || item.quote_price || '--'}}</text>
            <text class="fav-date">{{item.created_at || ''}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:elif="{{!loading && list.length === 0}}" class="empty-wrap">
      <empty-state title="暂无收藏" desc="去估价页面收藏喜欢的报价吧" />
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="no-more">— 已经到底了 —</view>
  </block>
</view>
