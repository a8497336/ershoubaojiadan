@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.list-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.recording-item { background: var(--color-background-white); border-radius: var(--radius-lg); padding: 24rpx; box-shadow: var(--shadow-sm); }
.rec-title { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: var(--font-weight-medium); display: block; margin-bottom: 8rpx; }
.rec-time { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.rec-duration { font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: 6rpx; }
.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
.empty-wrap { padding: 80rpx 0; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
