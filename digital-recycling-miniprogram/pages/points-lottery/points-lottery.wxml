<view class="page-container">
  <view class="points-header">
    <text class="ph-label">可用积分</text>
    <text class="ph-value">{{points}}</text>
    <text class="ph-cost">每次抽奖消耗10积分</text>
  </view>

  <view class="lottery-area">
    <view class="lottery-wheel">
      <view class="lw-item {{index === resultIndex && isSpinning ? 'active' : ''}}" wx:for="{{lotteryList}}" wx:key="index" data-index="{{index}}" bindtap="onPrizeTap">
        <image class="lw-icon" src="/images/icons/{{item.icon}}.svg" mode="aspectFit" />
        <text class="lw-name">{{item.name}}</text>
      </view>
      <view class="lw-center {{isSpinning ? 'disabled' : ''}}" bindtap="onStartLottery">
        <text class="lwc-text">{{isSpinning ? '抽奖中' : '抽奖'}}</text>
      </view>
    </view>
  </view>

  <view class="records-section">
    <view class="rs-header"><text class="rs-title">抽奖记录</text></view>
    <view wx:if="{{records.length > 0 && !loading}}" class="records-list">
      <view class="rec-item" wx:for="{{records}}" wx:key="id">
        <text class="rec-prize">{{item.prize_name || item.prize || '奖品'}}</text>
        <text class="rec-time">{{item.created_at || ''}}</text>
      </view>
    </view>
    <view wx:elif="{{!loading && records.length === 0}}" class="empty-records">暂无抽奖记录</view>
    <view wx:if="{{loading}}" class="rec-loading"><loading-spinner size="small" /></view>
  </view>
</view>
