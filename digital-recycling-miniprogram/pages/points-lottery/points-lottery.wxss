@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.points-header { background: var(--color-primary-gradient); padding: 40rpx 24rpx; display: flex; flex-direction: column; align-items: center; color: var(--color-text-inverse); }
.ph-label { font-size: var(--font-size-sm); opacity: 0.8; margin-bottom: 8rpx; }
.ph-value { font-size: var(--font-size-4xl); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.ph-cost { font-size: var(--font-size-xs); opacity: 0.8; }
.lottery-area { padding: 48rpx 24rpx; display: flex; justify-content: center; }
.lottery-wheel { position: relative; width: 600rpx; height: 600rpx; display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr); gap: 8rpx; border-radius: 50%; overflow: hidden; background: linear-gradient(135deg, #fff8e0, #fff3c0); padding: 16rpx; box-shadow: var(--shadow-lg); }
.lw-item { display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--color-background-white); border-radius: var(--radius-md); transition: all 0.2s ease; gap: 6rpx; }
.lw-item.active { background: var(--color-primary-light); border: 4rpx solid var(--color-primary); transform: scale(1.05); }
.lw-icon { width: 48rpx; height: 48rpx; }
.lw-name { font-size: 20rpx; color: var(--color-text-primary); }
.lw-center { grid-column: 2; grid-row: 2; display: flex; align-items: center; justify-content: center; background: var(--color-primary-gradient); border-radius: 50%; color: var(--color-text-inverse); box-shadow: var(--shadow-primary); }
.lw-center.disabled { opacity: 0.6; }
.lwc-text { font-size: var(--font-size-xl); font-weight: var(--font-weight-bold); }
.records-section { margin: 0 24rpx; background: var(--color-background-white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
.rs-header { padding: 24rpx; border-bottom: 1rpx solid var(--color-border-light); }
.rs-title { font-size: var(--font-size-md); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
.records-list { padding: 0 24rpx; }
.rec-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--color-border-light); }
.rec-item:last-child { border-bottom: none; }
.rec-prize { font-size: var(--font-size-base); color: var(--color-text-primary); }
.rec-time { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.empty-records { text-align: center; padding: 48rpx; color: var(--color-text-tertiary); font-size: var(--font-size-sm); }
.rec-loading { display: flex; justify-content: center; padding: 40rpx; }
