@import '/styles/design-tokens.wxss';

.page-container {
  background: var(--color-background);
  padding-bottom: 200rpx;
}

/* ===== 顶部导航栏 ===== */
.nav-bar {
  background: var(--color-primary);
  height: auto;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: sticky;
  z-index: 100;
}
.nav-bar .more-btn {
  color: var(--color-text-inverse);
  font-size: 36rpx;
  letter-spacing: 4rpx;
}
.nav-bar .title {
  color: var(--color-text-inverse);
  font-size: 34rpx;
  font-weight: var(--font-weight-medium);
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.nav-bar .capsule {
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 32rpx;
  overflow: hidden;
}
.nav-bar .capsule text {
  color: var(--color-text-inverse);
  padding: 8rpx 20rpx;
  font-size: 28rpx;
  border-right: 2rpx solid rgba(255,255,255,0.3);
}
.nav-bar .capsule text:last-child { border-right: none; }

/* ===== Banner ===== */
.banner {
  width: 100%;
  height: 320rpx;
  background: var(--color-primary-gradient);
  position: relative;
  overflow: hidden;
}
.banner-swiper {
  width: 100%;
  height: 100%;
}
.banner-image {
  width: 100%;
  height: 100%;
}
.banner-text {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: var(--color-text-inverse);
  width: 100%;
  height: 100%;
}
.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  letter-spacing: 4rpx;
}
.banner-search {
  font-size: 26rpx;
  margin: 8rpx 0;
}
.banner-title {
  font-size: 56rpx;
  font-weight: var(--font-weight-bold);
  text-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 8rpx;
}
.banner-dots {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}
.banner-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  transition: all var(--transition-normal);
}
.banner-dot.active {
  background: var(--color-text-inverse);
  width: 28rpx;
  border-radius: 6rpx;
}

/* ===== 功能入口网格 ===== */
.func-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 24rpx;
  background: var(--color-background);
}

.func-item {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
  flex: 1;
  margin: 0 8rpx;
}
.func-item:active {
  background: var(--card-active-bg);
  transform: scale(var(--card-hover-scale));
}

.func-item-icon-em {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: var(--color-primary-light);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.func-item .func-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  text-align: center;
}

.func-arrow {
  display: none;
}

/* ===== 公告栏 ===== */
.notice-bar {
  background: var(--color-background-white);
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid var(--color-border-light);
  overflow: hidden;
  gap: 12rpx;
}
.notice-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
.notice-tag {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-size-sm);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  font-weight: var(--font-weight-medium);
}
.notice-scroll-wrapper {
  flex: 1;
  height: 40rpx;
  overflow: hidden;
  position: relative;
}
.notice-scroll-inner {
  transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.notice-scroll-item {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  white-space: nowrap;
}
.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.notice-time {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  white-space: nowrap;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ===== 附近门店 ===== */
.store-card {
  background: var(--color-background-white);
  margin: 16rpx 24rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}
.store-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.store-tag {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-size-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}
.store-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  flex: 1;
  margin-left: 16rpx;
}
.store-distance {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.store-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 26rpx;
}
.store-info-row:active {
  background: var(--card-active-bg);
  border-radius: var(--radius-sm);
}

.store-label {
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.store-action {
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}

.store-address {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 12rpx;
  line-height: 1.5;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.store-address:active {
  background: var(--card-active-bg);
  border-radius: var(--radius-sm);
}
.store-address .store-action {
  margin-left: 16rpx;
  white-space: nowrap;
}

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 20rpx 24rpx;
}

.search-input {
  background: var(--color-background-white);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border: 2rpx solid var(--color-border);
}
.search-input .search-icon-img {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.search-input input {
  border: none;
  outline: none;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  width: 100%;
  background: transparent;
}

/* ===== 分类Tab ===== */
.category-tabs {
  display: flex;
  background: var(--color-background-white);
  padding: 0 24rpx;
  border-bottom: 2rpx solid var(--color-border-light);
}
.cat-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  position: relative;
}
.cat-tab.active {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.cat-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

/* ===== 常用报价 ===== */
.common-quote {
  background: var(--color-background-white);
  padding: 24rpx;
  display: flex;
  gap: 40rpx;
  font-size: var(--font-size-base);
}
.common-quote .active {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.common-quote .empty {
  color: var(--color-primary);
}

.common-quote-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-background-white);
  padding: 24rpx;
}
.common-quote-header .active {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  font-size: var(--font-size-base);
}
.common-quote-header .more {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.hot-price-list {
  white-space: nowrap;
  padding: 0 24rpx;
  background: var(--color-background-white);
}
.hot-price-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  background: var(--color-background-gray);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  vertical-align: top;
}
.hot-price-item:last-child { margin-right: 0; }
.price-brand {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.price-model {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  margin-top: 8rpx;
}
.price-value {
  font-size: var(--font-size-md);
  color: var(--color-price-high);
  font-weight: var(--font-weight-bold);
  margin-top: 12rpx;
}

/* ===== 区块标题 ===== */
.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  padding: 32rpx 24rpx 20rpx;
  background: var(--color-background-white);
  margin-top: 16rpx;
}

/* ===== 品牌网格 ===== */
.brand-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rpx;
  background: var(--color-border-light);
}
.brand-item {
  background: var(--color-background-white);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 8rpx;
  position: relative;
}
.brand-item:active { background: var(--card-active-bg); }

.brand-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-inverse);
  margin-bottom: 12rpx;
  position: relative;
}
.brand-icon image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.brand-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

.update-tag {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: var(--color-accent);
  color: var(--color-primary);
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-bold);
  white-space: nowrap;
  z-index: 2;
}

.difficult-grid .brand-icon {
  width: 96rpx;
  height: 96rpx;
}

/* ===== 品牌颜色 ===== */
.bg-huawei { background: #cf0a2c; }
.bg-vivo { background: #415fff; }
.bg-oppo { background: #009b4d; }
.bg-realme { background: #ffc915; color: var(--color-text-primary) !important; }
.bg-xiaomi { background: #ff6900; }
.bg-apple { background: #555; }
.bg-samsung { background: #1428a0; }
.bg-oneplus { background: #f50514; }
.bg-nokia { background: #124191; }
.bg-gionee, .bg-jinli { background: #e66b1a; }
.bg-meitu { background: #ff4d94; }
.bg-meizu { background: #00b4ff; }
.bg-nubia { background: #1a1a1a; }
.bg-360 { background: #4caf50; }
.bg-smartisan { background: #e02e24; }
.bg-zte { background: #00a0e9; }
.bg-coolpad { background: #00b0f0; }
.bg-lenovo { background: #e2231a; }
.bg-htc { background: #8bc34a; }
.bg-blackberry { background: #000; }
.bg-hisense { background: #00a0e9; }
.bg-doov { background: #e91e63; }
.bg-gree { background: #ff0000; }
.bg-moto { background: #000; }
.bg-asus { background: #00539b; }
.bg-royole { background: #ff6b00; }
.bg-google { background: #4285f4; }
.bg-8848 { background: #1a1a1a; }
.bg-sugar { background: #ff6b6b; }
.bg-bbk { background: #ff2d4a; }
.bg-leeco { background: #2196f3; }
.bg-tcl { background: #ff0000; }
.bg-chinamobile { background: #0099cc; }

/* ===== 视频教程区 ===== */
.video-section {
  background: var(--color-background-white);
  padding: 0 24rpx 32rpx;
  margin-top: 16rpx;
}
.video-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}
.video-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}
.video-more {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.video-tabs {
  display: flex;
  gap: 40rpx;
  border-bottom: 2rpx solid var(--color-border-light);
  margin-bottom: 24rpx;
}
.video-tab {
  padding: 16rpx 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  position: relative;
}
.video-tab.active {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}
.video-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--color-primary);
}

.video-list { white-space: nowrap; }

.video-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 20rpx;
  vertical-align: top;
}
.video-card:last-child { margin-right: 0; }
.video-thumb {
  width: 220rpx;
  height: 160rpx;
  background: var(--skeleton-base);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.video-cover {
  width: 100%;
  height: 100%;
}
.video-default-icon {
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.video-play-btn {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}
.video-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  margin-top: 12rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ===== 服务流程 ===== */
.service-flow {
  background: var(--color-background-white);
  margin-top: 16rpx;
  padding: 32rpx 24rpx;
}
.flow-title {
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-primary);
  margin-bottom: 32rpx;
  font-weight: var(--font-weight-medium);
}
.flow-steps {
  display: flex;
  justify-content: space-around;
}
.flow-step {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.flow-icon-em {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  border-radius: var(--radius-md);
}
.flow-step-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ===== CTA按钮 ===== */
.cta-btn {
  margin: 32rpx 24rpx;
}

.cta-btn button {
  width: 100%;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--radius-full);
  padding: 28rpx 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  box-shadow: var(--shadow-primary);
}
.cta-btn button:active {
  background: var(--color-primary-dark);
}

/* ===== 底部信息 ===== */
.footer-info {
  text-align: center;
  padding: 32rpx 24rpx;
}
.footer-title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  display: block;
}
.footer-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
  display: block;
}
.footer-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--color-border-light);
}
.footer-action {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ===== 返回顶部 ===== */
.back-top {
  position: fixed;
  bottom: 140rpx;
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--color-background-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: var(--shadow-md);
  z-index: 99;
}

/* ===== Toast提示 ===== */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: var(--color-text-inverse);
  padding: 20rpx 48rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  z-index: 9999;
  pointer-events: none;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.custom-toast.show { opacity: 1; }

/* ===== 全屏加载 ===== */
.full-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}

/* ===== 网络错误 ===== */
.network-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
  background: var(--color-background-white);
}
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-title {
  font-size: var(--font-size-xl);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-bold);
  margin-bottom: 16rpx;
}
.error-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
}

.offline-banner {
  background: var(--color-warning-light);
  color: var(--color-warning);
  text-align: center;
  padding: 16rpx;
  font-size: var(--font-size-sm);
}

.empty-placeholder {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

/* 底部权限弹窗 */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--transition-normal), visibility var(--transition-normal);
}
.sheet-mask.show { opacity: 1; visibility: visible; }

.sheet-container {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
}

.sheet-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}
.sheet-logo-img { width: 48rpx; height: 48rpx; border-radius: 50%; }
.sheet-title { font-size: 32rpx; font-weight: 600; color: #333; flex: 1; }
.sheet-info-icon { font-size: 28rpx; color: #999; }

.sheet-body { margin-bottom: 36rpx; }
.sheet-heading { font-size: 34rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.sheet-desc { font-size: 26rpx; color: #666; line-height: 1.6; display: block; }
.privacy-desc { text-align: justify; }
.privacy-body { padding-top: 20rpx; }

.sheet-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.sheet-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
}
.sheet-btn::after { border: none; }
.sheet-btn-deny { background: #f5f5f5; color: #333; }
.sheet-btn-allow { background: #07c160; color: #fff; }
.sheet-btn-allow.btn-disabled { opacity: 0.4; pointer-events: none; }

.sheet-agreement {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  flex-shrink: 0;
  position: relative;
}
.agreement-checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}
.agreement-checkbox.checked::after {
  content: '';
  position: absolute;
  left: 10rpx; top: 4rpx;
  width: 12rpx; height: 18rpx;
  border: 2rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}
