@import '/styles/design-tokens.wxss';

/* ===== 页面容器 ===== */
.page-container {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: #f5f5f5;
  padding-bottom: 200rpx;
  /* 注意：小程序无法设置max-width，页面会占满屏幕宽度 */
}

/* 响应式调整 - 匹配H5端的媒体查询 */
@media (max-width: 375px) {
  .banner {
    height: 280rpx; /* 140px */
  }
  .banner-title {
    font-size: 48rpx; /* 24px */
  }
  .func-grid {
    gap: 12rpx;
    padding: 20rpx;
  }
  .func-item {
    padding: 20rpx 16rpx;
  }
  .func-title {
    font-size: 28rpx;
  }
  .func-desc {
    font-size: 20rpx;
  }
  .go-btn {
    font-size: 20rpx;
    padding: 2rpx 12rpx;
    margin-top: 12rpx;
  }
  .func-icon {
    width: 36rpx;
    height: 36rpx;
    font-size: 24rpx;
    right: 12rpx;
    bottom: 12rpx;
  }
  .brand-item {
    padding: 24rpx 4rpx;
  }
  .brand-icon {
    width: 80rpx;
    height: 80rpx;
    font-size: 20rpx;
  }
  .brand-name {
    font-size: 22rpx;
  }
  .update-tag {
    font-size: 16rpx;
    padding: 2rpx 6rpx;
  }
  .difficult-grid .brand-icon {
    width: 84rpx;
    height: 84rpx;
  }
  .section-title {
    font-size: 30rpx;
    padding: 28rpx 24rpx 16rpx;
  }
  .flow-icon {
    width: 80rpx;
    height: 80rpx;
  }
  .flow-step-text {
    font-size: 22rpx;
  }
  .video-thumb {
    width: 200rpx;
    height: 144rpx;
  }
  .video-card {
    width: 200rpx;
  }
  .video-name {
    font-size: 22rpx;
  }
  .store-card {
    margin: 12rpx 20rpx;
    padding: 20rpx;
  }
  .search-bar {
    padding: 12rpx 20rpx;
  }
  .search-input {
    padding: 12rpx 24rpx;
  }
  .search-input input {
    font-size: 26rpx;
  }
  .cta-btn {
    margin: 28rpx 20rpx;
  }
  .cta-btn button {
    padding: 24rpx 0;
    font-size: 30rpx;
  }
}

@media (max-width: 320px) {
  .banner {
    height: 240rpx; /* 120px */
  }
  .banner-title {
    font-size: 40rpx; /* 20px */
  }
  .func-grid {
    gap: 8rpx;
    padding: 16rpx;
  }
  .func-item {
    padding: 16rpx 12rpx;
    border-radius: 16rpx;
  }
  .func-title {
    font-size: 26rpx;
  }
  .func-desc {
    font-size: 18rpx;
  }
  .go-btn {
    font-size: 18rpx;
    padding: 2rpx 10rpx;
    margin-top: 8rpx;
  }
  .func-icon {
    width: 32rpx;
    height: 32rpx;
    font-size: 20rpx;
    right: 8rpx;
    bottom: 8rpx;
  }
  .brand-item {
    padding: 20rpx 4rpx;
  }
  .brand-icon {
    width: 72rpx;
    height: 72rpx;
    font-size: 18rpx;
  }
  .brand-name {
    font-size: 20rpx;
  }
  .update-tag {
    font-size: 14rpx;
    padding: 2rpx 4rpx;
    top: 12rpx;
  }
  .difficult-grid .brand-icon {
    width: 76rpx;
    height: 76rpx;
  }
  .section-title {
    font-size: 28rpx;
    padding: 24rpx 20rpx 16rpx;
  }
  .flow-icon {
    width: 72rpx;
    height: 72rpx;
  }
  .flow-step-text {
    font-size: 20rpx;
  }
  .video-thumb {
    width: 180rpx;
    height: 128rpx;
  }
  .video-card {
    width: 180rpx;
  }
  .video-name {
    font-size: 20rpx;
  }
  .store-card {
    margin: 12rpx 16rpx;
    padding: 16rpx;
  }
  .store-header {
    margin-bottom: 16rpx;
  }
  .store-name {
    font-size: 28rpx;
  }
  .search-bar {
    padding: 12rpx 16rpx;
  }
  .search-input {
    padding: 12rpx 20rpx;
  }
  .search-input input {
    font-size: 24rpx;
  }
  .cta-btn {
    margin: 24rpx 16rpx;
  }
  .cta-btn button {
    padding: 20rpx 0;
    font-size: 28rpx;
  }
  .cat-tab {
    font-size: 26rpx;
    padding: 20rpx 0;
  }
  .video-tab {
    font-size: 26rpx;
  }
  .notice-text {
    font-size: 24rpx;
  }
  .footer-action {
    font-size: 24rpx;
  }
}

/* ===== 顶部导航栏 ===== */
.nav-bar {
  background: #ff2d4a;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-bar .more-btn {
  color: #fff;
  font-size: 36rpx;
  letter-spacing: 4rpx;
}
.nav-bar .title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.nav-bar .capsule {
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 32rpx;
  overflow: hidden;
}
.nav-bar .capsule text {
  color: #fff;
  padding: 8rpx 20rpx;
  font-size: 28rpx;
  border-right: 2rpx solid rgba(255,255,255,0.3);
}
.nav-bar .capsule text:last-child { border-right: none; }

/* ===== Banner ===== */
.banner {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #ff2d4a 0%, #ff6b6b 100%);
  position: relative;
  overflow: hidden;
}
.banner-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #fff;
}
.banner-image {
  width: 100%;
  height: 100%;
}
.banner-text {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #fff;
}
.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  letter-spacing: 4rpx;
}
.banner-search {
  font-size: 26rpx;
  margin: 8rpx 0;
}
.banner-title {
  font-size: 56rpx;
  font-weight: bold;
  text-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 8rpx;
}
.banner-dots {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}
.banner-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
}
.banner-dot.active {
  background: #fff;
  width: 28rpx;
  border-radius: 6rpx;
}

/* ===== 功能入口网格 ===== */
.func-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 24rpx;
  background: #f5f5f5;
}

.func-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  position: relative;
}
.func-item:active { background: #f8f8f8; }

.func-item .func-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  display: block;
}
.func-item .func-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.4;
  display: block;
}
.func-item .go-btn {
  display: inline-flex;
  align-items: center;
  background: #ff2d4a;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 16rpx;
}
.func-item .func-icon {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* ===== 公告栏 ===== */
.notice-bar {
  background: #fff;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  overflow: hidden;
}
.notice-tag {
  background: #ff2d4a;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.notice-scroll-wrapper {
  flex: 1;
  height: 40rpx;
  overflow: hidden;
  position: relative;
}
.notice-scroll-inner {
  transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.notice-scroll-item {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  white-space: nowrap;
}
.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.notice-time {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ===== 附近门店 ===== */
.store-card {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}
.store-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.store-tag {
  background: #ff2d4a;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.store-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  margin-left: 16rpx;
}
.store-distance { font-size: 26rpx; color: #999; }

.store-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 26rpx;
}
.store-info-row:active { background: #f9f9f9; border-radius: 8rpx; }

.store-label {
  color: #666;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.store-action { color: #ff2d4a; font-size: 24rpx; }

.store-address {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
  line-height: 1.5;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.store-address:active { background: #f9f9f9; border-radius: 8rpx; }
.store-address .store-action { color: #ff2d4a; font-size: 24rpx; margin-left: 16rpx; white-space: nowrap; }

/* ===== 搜索栏 ===== */
.search-bar { padding: 20rpx 24rpx; }

.search-input {
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border: 2rpx solid #eee;
}
.search-input .search-icon-img {
  width: 32rpx;
  height: 32rpx;
  color: #999;
  margin-right: 16rpx;
  font-size: 28rpx;
}
.search-input input {
  border: none;
  outline: none;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  background: transparent;
}

/* ===== 分类Tab ===== */
.category-tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.cat-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.cat-tab.active {
  color: #ff2d4a;
  font-weight: 600;
}
.cat-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: #ff2d4a;
  border-radius: 4rpx;
}

/* ===== 常用报价 ===== */
.common-quote {
  background: #fff;
  padding: 24rpx;
  display: flex;
  gap: 40rpx;
  font-size: 28rpx;
}
.common-quote .active { color: #333; font-weight: 500; }
.common-quote .empty { color: #ff2d4a; }

.common-quote-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx;
}
.common-quote-header .active { color: #333; font-weight: 500; font-size: 28rpx; }
.common-quote-header .more { font-size: 26rpx; color: #999; }

.hot-price-list { white-space: nowrap; padding: 0 24rpx; }
.hot-price-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  vertical-align: top;
}
.hot-price-item:last-child { margin-right: 0; }
.price-brand { font-size: 22rpx; color: #999; }
.price-model { font-size: 26rpx; color: #333; font-weight: 500; margin-top: 8rpx; }
.price-value { font-size: 32rpx; color: var(--color-price-high); font-weight: bold; margin-top: 12rpx; }

/* ===== 区块标题 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 32rpx 24rpx 20rpx;
  background: #fff;
  margin-top: 16rpx;
}

/* ===== 品牌网格 ===== */
.brand-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rpx;
  background: #f0f0f0;
}
.brand-item {
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 8rpx;
  position: relative;
}
.brand-item:active { background: #f8f8f8; }

.brand-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
}
.brand-icon image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.brand-name { font-size: 24rpx; color: #333; text-align: center; }

.update-tag {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #ffd700;
  color: #ff2d4a;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: bold;
  white-space: nowrap;
  z-index: 2;
}

/* 疑难机型圆形 */
.difficult-grid .brand-icon {
  width: 96rpx;
  height: 96rpx;
}

/* ===== 品牌颜色 ===== */
.bg-huawei { background: #cf0a2c; }
.bg-vivo { background: #415fff; }
.bg-oppo { background: #009b4d; }
.bg-realme { background: #ffc915; color: #333 !important; }
.bg-xiaomi { background: #ff6900; }
.bg-apple { background: #555; }
.bg-samsung { background: #1428a0; }
.bg-oneplus { background: #f50514; }
.bg-nokia { background: #124191; }
.bg-gionee, .bg-jinli { background: #e66b1a; }
.bg-meitu { background: #ff4d94; }
.bg-meizu { background: #00b4ff; }
.bg-nubia { background: #1a1a1a; }
.bg-360 { background: #4caf50; }
.bg-smartisan { background: #e02e24; }
.bg-zte { background: #00a0e9; }
.bg-coolpad { background: #00b0f0; }
.bg-lenovo { background: #e2231a; }
.bg-htc { background: #8bc34a; }
.bg-blackberry { background: #000; }
.bg-hisense { background: #00a0e9; }
.bg-doov { background: #e91e63; }
.bg-gree { background: #ff0000; }
.bg-moto { background: #000; }
.bg-asus { background: #00539b; }
.bg-royole { background: #ff6b00; }
.bg-google { background: #4285f4; }
.bg-8848 { background: #1a1a1a; }
.bg-sugar { background: #ff6b6b; }
.bg-bbk { background: #ff2d4a; }
.bg-leeco { background: #2196f3; }
.bg-tcl { background: #ff0000; }
.bg-chinamobile { background: #0099cc; }

/* ===== 视频教程区 ===== */
.video-section {
  background: #fff;
  padding: 0 24rpx 32rpx;
}
.video-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}
.video-title { font-size: 32rpx; font-weight: bold; color: #333; }
.video-more { font-size: 26rpx; color: #999; }

.video-tabs {
  display: flex;
  gap: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.video-tab {
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.video-tab.active {
  color: #333;
  font-weight: 600;
}
.video-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #ff2d4a;
}

.video-list {
  white-space: nowrap;
}

.video-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 20rpx;
  vertical-align: top;
}
.video-card:last-child {
  margin-right: 0;
}
.video-thumb {
  width: 220rpx;
  height: 160rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  position: relative;
  overflow: hidden;
}
.video-cover {
  width: 100%;
  height: 100%;
}
.video-play-btn {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}
.video-name {
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ===== 服务流程 ===== */
.service-flow {
  background: #fff;
  margin-top: 16rpx;
  padding: 32rpx 24rpx;
}
.flow-title {
  text-align: center;
  font-size: 28rpx;
  color: #ff2d4a;
  margin-bottom: 32rpx;
  font-weight: 500;
}
.flow-steps { display: flex; justify-content: space-around; }
.flow-step { text-align: center; }
.flow-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin: 0 auto 12rpx;
}
.flow-step-text { font-size: 24rpx; color: #666; }

/* ===== CTA按钮 ===== */
.cta-btn { margin: 32rpx 24rpx; }

.cta-btn button {
  width: 100%;
  background: #ff2d4a;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}
.cta-btn button:active { background: #e62540; }

/* ===== 底部信息 ===== */
.footer-info {
  text-align: center;
  padding: 32rpx 24rpx;
}
.footer-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}
.footer-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
.footer-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #f0f0f0;
}
.footer-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

/* ===== 返回顶部 ===== */
.back-top {
  position: fixed;
  bottom: 140rpx;
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  font-size: 36rpx;
  color: #ff2d4a;
  z-index: 99;
}
.back-top:active { background: #f8f8f8; }

/* ===== Toast提示 ===== */
.custom-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 9999;
  pointer-events: none;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.custom-toast.show { opacity: 1; }

/* ===== 全屏加载 ===== */
.full-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}

/* ===== 网络错误 ===== */
.network-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
  background: #fff;
}
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-title { font-size: 36rpx; color: #333; font-weight: bold; margin-bottom: 16rpx; }
.error-desc { font-size: 28rpx; color: #999; }

.offline-banner {
  background: #fff3cd;
  color: #856404;
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
}

.empty-placeholder {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
