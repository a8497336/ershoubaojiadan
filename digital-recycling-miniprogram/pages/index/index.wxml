<view class="page-container" style="{{pageStyle}}">
  <view wx:if="{{!online}}" class="offline-banner">当前网络不可用，请检查网络连接</view>

  <!-- 加载中 -->
  <view wx:if="{{loading && !networkError}}" class="full-loading">
    <loading-spinner size="medium" color="primary" text="加载中..." />
  </view>

  <!-- 网络错误 -->
  <view wx:if="{{networkError}}" class="network-error" bindtap="init">
    <text class="error-icon">⚠</text>
    <text class="error-title">网络连接失败</text>
    <text class="error-desc">点击屏幕重新加载</text>
  </view>

  <block wx:if="{{!loading && !networkError}}">
    <!-- 顶部导航栏 -->
    <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
      <view class="title">联赢电子回收网</view>
    </view>

    <!-- Banner轮播 -->
    <view class="banner" wx:if="{{banners.length > 0}}">
      <swiper class="banner-swiper" current="{{bannerCurrent}}" autoplay="{{true}}" interval="3000" duration="500" circular="{{true}}" bindchange="onBannerChange">
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <image wx:if="{{item.image}}" src="{{item.image}}" class="banner-image" mode="aspectFill" />
          <view wx:else class="banner-text">
            <text class="banner-subtitle">{{item.subtitle || 'BUSINESS PARTNER'}}</text>
            <text class="banner-search">{{item.tag || 'SEARCH'}}</text>
            <text class="banner-title">{{item.title || '寻找城市合伙人'}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view class="banner-dots">
        <view class="banner-dot {{bannerCurrent === index ? 'active' : ''}}" wx:for="{{banners}}" wx:key="index"></view>
      </view>
    </view>
    <view class="banner" wx:else>
      <view class="banner-text" style="width:100%;height:100%;">
        <text class="banner-subtitle">BUSINESS PARTNER</text>
        <text class="banner-search">SEARCH</text>
        <text class="banner-title">寻找城市合伙人</text>
      </view>
      <view class="banner-dots">
        <view class="banner-dot {{bannerCurrent === 0 ? 'active' : ''}}"></view>
        <view class="banner-dot {{bannerCurrent === 1 ? 'active' : ''}}"></view>
        <view class="banner-dot {{bannerCurrent === 2 ? 'active' : ''}}"></view>
      </view>
    </view>

    <!-- 功能入口网格 -->
    <view class="func-grid">
      <view class="func-item" bindtap="goToBrandList">
        <text class="func-item-icon-em">🔍</text>
        <text class="func-title">快速查价</text>
      </view>
      <view class="func-item" bindtap="goToScanPrice">
        <text class="func-item-icon-em">📷</text>
        <text class="func-title">拍照查价</text>
      </view>
      <view class="func-item" bindtap="goToInvite">
        <text class="func-item-icon-em">📞</text>
        <text class="func-title">邀请好友</text>
      </view>
    </view>

    <!-- 公告栏 -->
    <view class="notice-bar" wx:if="{{displayAnnouncements.length > 0}}">
      <view class="notice-tag">🔔 公告</view>
      <view class="notice-scroll-wrapper">
        <view class="notice-scroll-inner" style="transform: translateY(-{{currentAnnouncementIndex * 40}}rpx);">
          <view class="notice-scroll-item" wx:for="{{displayAnnouncements}}" wx:key="index">
            <text class="notice-text">{{item.title}}</text>
            <text class="notice-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>
  
    <!-- 加载中骨架(onLoad 自动调 _autoLoadNearbyStore 期间显示) -->
    <view class="store-card store-card-loading" wx:if="{{storeLoading && !storeInfo}}">
      <view class="store-loading-icon">📍</view>
      <view class="store-loading-text">正在定位查找最近门店...</view>
    </view>

    <!-- 已有门店信息时显示门店卡片 -->
    <view class="store-card" wx:elif="{{storeInfo}}">
      <view class="store-header">
        <text class="store-tag">附近门店</text>
        <text class="store-name">{{storeInfo.name || '联赢门店'}}</text>
        <text wx:if="{{storeInfo.distance}}" class="store-distance">距离 {{storeInfo.distance}} km</text>
        <text wx:else class="store-distance store-distance-warn">距离暂不可用</text>
      </view>
      <view class="store-info-row" bindtap="makePhoneCall" data-phone="{{storeInfo.phone || '18755875222'}}">
        <view class="store-label">
          <text>📞 {{storeInfo.contact_name || '联系人'}} {{storeInfo.phone || storeInfo.contact_phone || '18755875222'}}</text>
        </view>
        <text class="store-action">拨打 ></text>
      </view>
      <view class="store-info-row" bindtap="copyWechat" data-wxid="{{storeInfo.wechat || '18755875222'}}">
        <view class="store-label">
          <text>💬 {{storeInfo.wechat || '18755875222'}}</text>
        </view>
        <text class="store-action">复制 ></text>
      </view>
      <view class="store-address" bindtap="openLocation">
        <view class="store-label" style="flex:1;">
          <text>📍 {{storeInfo.province || "" }}{{storeInfo.city || "" }}{{storeInfo.address || ""}}</text>
        </view>
        <text class="store-action">导航 ></text>
      </view>
      <!-- <view class="store-debug-hint" wx:if="{{showDevTestBar}}">调试场景：可在下方 dev-test-bar 单独测试定位</view> -->
    </view>

    <!-- 开发者调试条（仅开发版可见）：参考 dom 的 5 按钮调试面板 + 系统信息 + 隐私/结果 + 日志 + 兼容性 + 错误码表 -->
    <view class="dev-test-bar" wx:if="{{showDevTestBar}}">
      <view class="dev-test-title">🔧 开发者定位调试（参考 dom）</view>

      <!-- 系统信息卡片 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">系统信息</view>
        <view class="dev-test-card-content mono">{{systemInfo || '加载中...'}}</view>
        <view class="dev-test-card-content mono">API 可用性: {{apiCheckText}}</view>
      </view>

      <!-- 5 按钮 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">调试按钮</view>
        <view class="dev-test-row">
          <view class="dev-test-btn dev-test-btn-primary" bindtap="onDevTestCheckPrivacy">[1] 检测隐私设置</view>
        </view>
        <view class="dev-test-row">
          <view class="dev-test-btn dev-test-btn-primary" bindtap="onDevTestRequirePrivacy">[2] 申请隐私授权</view>
        </view>
        <view class="dev-test-row">
          <view class="dev-test-btn dev-test-btn-primary"
                bindtap="onDevTestGetLocation"
                bindlongtap="onDevTestCopyLocation">[3] 获取模糊位置</view>
        </view>
        <view class="dev-test-hint">长按 [3] 复制 lat,lng 到剪贴板</view>
        <view class="dev-test-row">
          <view class="dev-test-btn dev-test-btn-secondary" bindtap="onDevTestFullFlow">[4] 一键完整流程</view>
        </view>
        <view class="dev-test-row">
          <view class="dev-test-btn dev-test-btn-ghost" bindtap="onDevTestClearCache">[5] 清除定位缓存</view>
        </view>
      </view>

      <!-- 隐私状态 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">隐私状态</view>
        <view class="dev-test-card-content mono {{privacyStatusClass}}">{{privacyStatus || '（尚未查询，点击 [1] 或 [2] 后查看）'}}</view>
      </view>

      <!-- 定位结果 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">最近定位结果</view>
        <view class="dev-test-card-content mono {{locationResultClass}}">{{locationResult || '（尚未定位，点击 [3] 或 [5] 后查看）'}}</view>
      </view>

      <!-- Console 日志 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">Console 日志（最近 10 条）</view>
        <view class="dev-test-log-list">
          <view wx:if="{{consoleLogs.length === 0}}" class="dev-test-log-empty">暂无日志</view>
          <view wx:for="{{consoleLogs}}" wx:key="index" class="dev-test-log-item log-{{item.level}}">
            {{item.text}}
          </view>
        </view>
      </view>

      <!-- API 兼容性 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">API 兼容性</view>
        <view class="dev-test-api-row"><text>wx.getPrivacySetting</text><text>要求 SDKVersion ≥ 2.32.3</text></view>
        <view class="dev-test-api-row"><text>wx.requirePrivacyAuthorize</text><text>要求 SDKVersion ≥ 3.0.0</text></view>
        <view class="dev-test-api-row"><text>wx.getFuzzyLocation</text><text>要求 SDKVersion ≥ 2.25.0</text></view>
        <view class="dev-test-api-row"><text>wx.onNeedPrivacyAuthorization</text><text>要求 SDKVersion ≥ 2.32.3</text></view>
      </view>

      <!-- 错误码速查表 -->
      <view class="dev-test-card">
        <view class="dev-test-card-title">错误码速查表</view>
        <view class="dev-test-err-table">
          <view>• system permission denied → 系统未授权微信位置权限（iOS）</view>
          <view>• ERROR_NOCELL&amp;WIFI_LOCATIONSWITCHOFF → 系统定位服务关闭</view>
          <view>• fail authorize / auth deny → 用户拒绝授权</view>
          <view>• fuzzyLocation:fail → 模糊位置接口调用失败（隐私协议未声明）</view>
          <view>• getPrivacySetting:fail → 隐私查询失败（基础库过旧）</view>
        </view>
      </view>

      <view class="dev-test-hint">提示：仅定位调试，不会写入 app.globalData / storeInfo / processStore</view>
    </view>

    <!-- 常用报价 -->
    <view class="common-quote-header">
      <text class="active">常用报价</text>
      <text class="more" bindtap="goToPriceQuote">查看全部 ></text>
    </view>
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-input">
        <text class="search-icon-img">🔍</text>
        <input type="text" placeholder="查找您想要看的机型报价" bindinput="onSearchInput" bindconfirm="handleSearch" />
      </view>
    </view>

    <!-- 分类Tab -->
    <view class="category-tabs" wx:if="{{categories.length > 0}}">
      <view class="cat-tab {{activeCategory === index ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-index="{{index}}">{{item.name}}</view>
    </view>


    <!-- <block wx:if="{{hotPriceList.length > 0}}">
      <scroll-view class="hot-price-list" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="hot-price-item" wx:for="{{hotPriceList}}" wx:key="id" bindtap="goToBrandList" data-id="{{item.brandId}}" data-name="{{item.brand}}">
          <view class="price-brand">{{item.brand}}</view>
          <view class="price-model">{{item.model}}</view>
          <view class="price-value">{{item.maxPrice}}</view>
        </view>
      </scroll-view>
    </block> -->
    <!-- <view wx:elif="{{!priceLoading}}" class="common-quote">
      <text class="active">常用报价</text>
      <text class="empty">暂无常用报价</text>
    </view> -->
    <!-- 分类品牌区 -->
    <view  wx:if="{{currentCategorySection}}">
      <view class="section-title">{{currentCategorySection.name}}回收报价</view>
      <view class="brand-grid {{currentCategorySection.code === 'difficult' ? 'difficult-grid' : ''}}">
        <view class="brand-item" wx:for="{{currentBrands}}" wx:key="id" bindtap="onBrandTap" data-id="{{item.id}}" data-name="{{item.name}}">
          <view wx:if="{{item.has_update}}" class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg_color || 'bg-apple'}}" style="{{item.icon_style}}">{{item.icon_text || item.name[0]}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>
    </view>

      <view   wx:else>
      <view class="section-title">废旧手机回收报价</view>
      <view class="brand-grid">
        <view class="brand-item" wx:for="{{phoneBrands}}" wx:key="index" bindtap="onBrandTap">
          <view class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}" style="{{item.iconStyle}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>

      <view class="section-title">废旧手机内配回收报价</view>
      <view class="brand-grid">
        <view class="brand-item" wx:for="{{internalBrands}}" wx:key="index" bindtap="onBrandTap">
          <view class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}" style="{{item.iconStyle}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>

      <view class="section-title">电子产品杂货回收报价</view>
      <view class="brand-grid">
        <view class="brand-item" wx:for="{{electronicsBrands}}" wx:key="index" bindtap="onBrandTap">
          <view class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}" style="{{item.iconStyle}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>

      <view class="section-title">疑难机型查看</view>
      <view class="brand-grid difficult-grid">
        <view class="brand-item" wx:for="{{difficultBrands}}" wx:key="index" bindtap="onBrandTap">
          <view wx:if="{{item.hasUpdate}}" class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>

      <view class="section-title">国机回收报价</view>
      <view class="brand-grid">
        <view class="brand-item" wx:for="{{goodPhoneBrands}}" wx:key="index" bindtap="onBrandTap">
          <view class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}" style="{{item.iconStyle}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>

      <view class="section-title">名酒回收报价</view>
      <view class="brand-grid">
        <view class="brand-item" wx:for="{{liquorBrands}}" wx:key="index" bindtap="onBrandTap">
          <view class="update-tag">今日更新</view>
          <view class="brand-icon {{item.bg}}" style="{{item.iconStyle}}">{{item.icon}}</view>
          <view class="brand-name">{{item.name}}</view>
        </view>
      </view>
    </view>

    <!-- 手机回收教程 -->

    <view class="video-section" wx:if="{{videos.length > 0}}">
      <view class="video-header">
        <text class="video-title">手机回收教程</text>
        <text class="video-more" bindtap="goToVideoList">全部视频 ></text>
      </view>
      <view class="video-tabs">
        <view class="video-tab {{activeVideoTab === index ? 'active' : ''}}" wx:for="{{videoTabs}}" wx:key="index" bindtap="switchVideoTab" data-index="{{index}}">{{item}}</view>
      </view>
      <scroll-view class="video-list" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="video-card" wx:for="{{filteredVideos}}" wx:key="id" bindtap="onVideoTap" data-index="{{index}}">
          <view class="video-thumb">
            <image wx:if="{{item.cover_image || item.cover}}" src="{{item.cover_image || item.cover}}" class="video-cover" mode="aspectFill" />
            <text wx:else class="video-default-icon">🎬</text>
            <view class="video-play-btn">▶</view>
          </view>
          <text class="video-name">{{item.title}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 服务流程 -->
    <view class="service-flow">
      <view class="flow-title">发货下单 → 到货验机 → 确认报价 → 完成收款</view>
      <view class="flow-steps">
        <view class="flow-step">
          <text class="flow-icon-em">🌳</text>
          <text class="flow-step-text">报价精准</text>
        </view>
        <view class="flow-step">
          <text class="flow-icon-em">🔍</text>
          <text class="flow-step-text">专业质检</text>
        </view>
        <view class="flow-step">
          <text class="flow-icon-em">🌵</text>
          <text class="flow-step-text">快速提现</text>
        </view>
        <view class="flow-step">
          <text class="flow-icon-em">🚀</text>
          <text class="flow-step-text">优质服务</text>
        </view>
      </view>
    </view>

    <!-- CTA按钮 -->
    <view class="cta-btn">
      <button bindtap="onBrandTap">回收下单</button>
    </view>

    <!-- 底部信息 -->
    <view class="footer-info">
      <text class="footer-title">联赢电子回收真诚服务好每一位客户</text>
      <text class="footer-desc">深耕十余年始终为您提供最新最可靠的回收报价</text>
      <view class="footer-actions">
        <view class="footer-action" data-wxid="15555962610" bindtap="copyWechat">
          <text>💬 添加微信</text>
        </view>
        <view class="footer-action" bindtap="makePhoneCall" data-phone="15555962610">
          <text>📞 客服电话</text>
        </view>
        <view class="footer-action" bindtap="goToStoreList">
          <text>🗧 门店列表</text>
        </view>
      </view>
    </view>

    <!-- Toast提示 -->
    <view class="custom-toast {{toastVisible ? 'show' : ''}}">{{toastMsg}}</view>

    <!-- 返回顶部 -->
    <view wx:if="{{showBackTop}}" class="back-top" bindtap="scrollToTop">🚀</view>

    <!-- 定位隐私授权弹窗已移除(onLoad 自动调 _autoLoadNearbyStore,首次进入走 wx.requirePrivacyAuthorize 弹原生授权弹窗) -->

    <!-- 悬浮三按钮：电话 / 客服 / 问题 -->
    <view class="fab-stack {{showFab ? '' : 'fab-hidden'}}">
      <view class="fab-item" bindtap="onFabPhoneCall" hover-class="fab-item-hover">
        <text class="fab-item-icon">📞</text>
        <text class="fab-item-label">电话</text>
      </view>
      <view class="fab-divider"></view>
      <button
        class="fab-item"
        open-type="contact"
        bindcontact="onContactTap"
        hover-class="fab-item-hover"
        session-from="home_page">
        <text class="fab-item-icon">🎧</text>
        <text class="fab-item-label">客服</text>
      </button>
      <view class="fab-divider"></view>
      <view class="fab-item" bindtap="onFabQuestion" hover-class="fab-item-hover">
        <text class="fab-item-icon">?</text>
        <text class="fab-item-label">问题</text>
      </view>
    </view>
  </block>

</view>
