@import '/styles/design-tokens.wxss';

.membership-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  position: relative;
  z-index: 100;
  flex-shrink: 0;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 64rpx;
}

.main-scroll {
  flex: 1;
  overflow: hidden;
}

.user-card {
  margin: 24rpx 32rpx;
  background: linear-gradient(135deg, #f5e6c8 0%, #e6c88a 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.user-avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.user-avatar-icon {
  width: 52rpx;
  height: 52rpx;
}

.user-text-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #8B4513;
}

.user-status {
  font-size: 26rpx;
  color: #B8860B;
  line-height: 1.5;
}

.income-num {
  color: #e6454a;
  font-weight: 700;
  font-size: 30rpx;
}

.section-block {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-head {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #e6a23c;
}

.privilege-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.privilege-card {
  background: linear-gradient(135deg, #fffbf0 0%, #fff8e7 100%);
  border: 1rpx solid #f0e0b0;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  overflow: hidden;
}

.privilege-header {
  display: flex;
  align-items: center;
}

.privilege-name {
  font-size: 27rpx;
  font-weight: 600;
  color: #8B4513;
}

.privilege-sub {
  font-size: 23rpx;
  color: #999;
  line-height: 1.4;
}

.privilege-badge-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.privilege-badge {
  background: linear-gradient(135deg, #e6a23c 0%, #d48806 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.privilege-badge-icon {
  font-size: 28rpx;
}

.rules-block {
  background: #fffef8;
  border: 1rpx solid #f0e0c0;
}

.rules-intro {
  font-size: 27rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.rule-item {
  font-size: 25rpx;
  color: #666;
  line-height: 1.75;
  padding: 10rpx 0;
  word-break: break-all;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 1000;
  flex-shrink: 0;
}

.safe-area-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.login-free-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #f5d77a 0%, #e6a23c 50%, #d48806 100%);
  color: #fff;
  border: none;
  border-radius: 46rpx;
  font-size: 33rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 28rpx rgba(230,162,60,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 92rpx;
  padding: 0;
  margin: 0;
}

.login-free-btn::after {
  border: none;
}

.login-free-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background: linear-gradient(135deg, #fffbf0 0%, #fff8e7 100%);
  border: 1rpx solid #f0e0b0;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #8B4513;
}

.plan-duration {
  font-size: 24rpx;
  color: #999;
}

.plan-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin: 8rpx 0;
}

.plan-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #e6454a;
}

.plan-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.plan-subscribers {
  font-size: 22rpx;
  color: #B8860B;
}

.plan-buy-btn {
  width: 100%;
  height: 76rpx;
  background: linear-gradient(135deg, #f5d77a 0%, #e6a23c 50%, #d48806 100%);
  color: #fff;
  border: none;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 76rpx;
  padding: 0;
  margin-top: 8rpx;
}

.plan-buy-btn::after {
  border: none;
}

.plan-buy-btn:active {
  opacity: 0.9;
}

.plan-buy-btn[disabled] {
  background: #ccc;
  color: #fff;
  box-shadow: none;
  opacity: 0.6;
}
