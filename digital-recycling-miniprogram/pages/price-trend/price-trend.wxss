@import '/styles/design-tokens.wxss';

.price-trend-page {
  background-color: var(--color-background);
  padding-bottom: 180rpx;
  min-height: 100vh;
}

.header-card {
  background: #fff;
  color: #333;
  padding: 30rpx;
}

.product-info {
  margin-bottom: 24rpx;
}

.product-brand {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.product-model {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.price-summary {
  display: flex;
  gap: 20rpx;
}

.summary-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  padding: 16rpx;
  border-radius: 12rpx;
  text-align: center;
}

.summary-item.change {
  background: rgba(255, 255, 255, 0.2);
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: bold;
}

.summary-value.price-high {
  font-size: 32rpx;
}

.summary-value.up {
  color: #52c41a;
}

.summary-value.down {
  color: #ff4d4f;
}

.time-selector {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.time-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.time-item.active {
  background: #ff2442;
  color: #fff;
  font-weight: 500;
}

.chart-section {
  position: relative;
  background: #fff;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.trend-canvas {
  width: 100%;
  height: 400rpx;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  transition: opacity 0.2s ease;
}

.legend-item-hover {
  background: rgba(0, 0, 0, 0.04);
}

.legend-item.legend-hidden {
  opacity: 0.4;
}

.legend-item.legend-hidden .legend-text {
  text-decoration: line-through;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.point-detail {
  position: absolute;
  z-index: 10;
  transform: translate(-50%, -100%);
  transition: opacity 0.2s ease;
  opacity: 0;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.point-detail.show {
  opacity: 1;
  pointer-events: auto;
}

.detail-content {
  background: rgba(0, 0, 0, 0.85);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  min-width: 140rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-condition {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.detail-date {
  font-size: 20rpx;
  opacity: 0.7;
  margin-bottom: 8rpx;
}

.detail-price {
  font-size: 28rpx;
}

.detail-arrow {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 14rpx solid rgba(0, 0, 0, 0.85);
}

.condition-selector {
  background: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.selector-title {
  font-size: 26rpx;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.condition-scroll {
  white-space: nowrap;
}

.condition-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: #f5f5f5;
  color: var(--color-text-secondary);
}

.condition-item.active {
  background: #ff2442;
  color: #fff;
}

.price-list-section {
  margin: 0 30rpx 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.price-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid var(--color-border-light);
}

.price-item:last-child {
  border-bottom: none;
}

.price-info {
  display: flex;
  flex-direction: column;
}

.condition-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.condition-code {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff2442;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.btn-outline {
  background: #fff;
  color: #ff2442;
  border: 2rpx solid #ff2442;
}

.btn-primary {
  background: #ff2442;
  color: #fff;
}

.loading-container {
  padding: 60rpx 30rpx;
}

.empty-container {
  padding: 120rpx 30rpx;
}
