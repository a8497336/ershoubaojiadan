<view class="profile-page" style="{{pageStyle}}">
  <view class="profile-header">
    <view class="profile-nav" style="padding-top: {{statusBarHeight}}px">
      <view class="nav-title">个人中心</view>
    </view>

    <view class="user-info-area" id="userInfoArea" bindtap="goToEditProfile">
      <view class="user-avatar-btn">
        <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-em">{{userInfo.nickname || userInfo.name || '用'}}</text>
        </view>
        <view class="avatar-edit-tag">更换头像</view>
      </view>
      <view class="user-details">
        <view class="u-name-text">{{userInfo.nickname || userInfo.name || '未设置昵称'}}</view>
        <view class="u-id">编号：{{userInfo.id || userInfo.userId || '--'}}</view>
        <view class="u-phone" wx:if="{{userInfo.phone}}">
          <text class="u-phone-icon">📞</text>
          <text>{{userInfo.phone}}</text>
        </view>
        <view class="u-phone" wx:else>
          <text class="u-phone-icon">📞</text>
          <text class="u-phone-tip">点击绑定手机号</text>
        </view>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-card" bindtap="goToWallet">
        <text class="stat-em">💰</text>
        <view class="stat-value">¥{{walletInfo.balance || '0.00'}}</view>
        <view class="stat-label">余额</view>
      </view>
      <view class="stat-card" bindtap="goToMyPoints">
        <text class="stat-em">⭐</text>
        <view class="stat-value">{{pointsInfo.points || '0'}}</view>
        <view class="stat-label">积分</view>
      </view>
    </view>
  </view>

  <view class="vip-card-outer" bindtap="goToMembership">
    <view class="vip-card">
      <view class="vip-left">
        <view class="vip-crown {{userInfo.is_vip ? 'active' : ''}}">
          <text class="vip-em">👑</text>
        </view>
        <view class="vip-info">
          <view class="vip-text">{{userInfo.is_vip ? (userInfo.planName || '') + '会员' : '非会员'}}</view>
          <view class="vip-desc" wx:if="{{userInfo.membershipExpired}}">会员已过期，请续期</view>
          <view class="vip-desc" wx:elif="{{userInfo.is_vip && userInfo.membershipExpireText}}">有效期至 {{userInfo.membershipExpireText}}</view>
          <view class="vip-desc" wx:elif="{{!userInfo.is_vip}}">开通会员享更多特权</view>
        </view>
      </view>
      <view class="vip-open-btn" wx:if="{{userInfo.membershipExpired}}">立刻续期</view>
      <view class="vip-open-btn" wx:elif="{{!userInfo.is_vip}}">立即开通</view>
      <view class="vip-open-btn renew" wx:else>续费</view>
    </view>
  </view>

  <view class="profile-tip-banner" wx:if="{{profileIncomplete}}" bindtap="goToEditProfile">
    <text class="tip-icon">💡</text>
    <view class="tip-content">
      <text class="tip-title">完善个人资料</text>
      <text class="tip-desc">您还有 {{incompleteCount}} 项资料未完善，完善后体验更佳</text>
    </view>
    <text class="tip-arrow">去完善 ></text>
  </view>

  <view class="quick-entry">
    <view wx:for="{{quickEntries}}" wx:key="index" class="quick-item" bindtap="onQuickEntryTap" data-index="{{index}}">
      <text class="quick-em">{{item.icon}}</text>
      <text class="quick-label">{{item.label}}</text>
      <view wx:if="{{item.badge > 0}}" class="quick-badge">{{item.badge > 99 ? '99+' : item.badge}}</view>
    </view>
  </view>

  <view class="points-section">
    <view class="section-header">
      <text class="s-title">积分活动</text>
      <text class="s-more" bindtap="goToMyPoints">查看更多 ></text>
    </view>
    <view class="points-grid">
      <view wx:for="{{pointActivities}}" wx:key="index" class="points-item" bindtap="onPointActivityTap" data-index="{{index}}">
        <text class="p-em">{{item.icon}}</text>
        <text class="p-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="func-section">
    <view class="func-grid-3">
      <view wx:for="{{commonFuncs}}" wx:key="index" class="func-item-compact" bindtap="onCommonFuncTap" data-index="{{index}}">
        <text class="ficon-em">{{item.icon}}</text>
        <text class="flabel">{{item.label}}</text>
        <view wx:if="{{item.badge}}" class="func-badge">{{item.badge}}</view>
      </view>
    </view>
  </view>

  <view class="vip-features" wx:if="{{userInfo.is_vip}}">
    <view class="vip-grid">
      <view wx:for="{{vipFeatList}}" wx:key="index" class="vip-feat-item" bindtap="onVipFeatTap" data-index="{{index}}">
        <text class="vf-em">{{item.icon}}</text>
        <text class="vf-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="contact-bar">
    <view wx:for="{{contactItems}}" wx:key="index" class="contact-item" bindtap="onContactTap" data-index="{{index}}">
      <text class="c-em">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>
