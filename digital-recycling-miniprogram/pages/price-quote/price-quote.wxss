@import '/styles/design-tokens.wxss';

.price-quote-page {
  background-color: var(--color-background);
  font-size: 24rpx;
  color: var(--color-text-primary);
  padding-bottom: 200rpx;
}

.search-section {
  padding: 16rpx 24rpx;
  background: var(--color-background-white);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-background);
  border-radius: var(--radius-full);
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-bar input {
  flex: 1;
  font-size: var(--font-size-sm);
  height: 48rpx;
}

.header-section {
  background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);
  color: #fff;
  padding: 12px 15px;
}

.header-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  margin-bottom: 20rpx;
  opacity: 0.9;
  /* color: #666666; */
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.header-info {
  font-size: 20rpx;
  line-height: 1.6;
  opacity: 0.95;
  background: rgba(255, 255, 255, 0.1);
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.header-info text {
  display: block;
  /* color: #666666; */
}

.header-rules {
  font-size: 18rpx;
  line-height: 1.5;
  opacity: 0.9;
}

.header-rules text {
  display: block;
  margin-bottom: 4rpx;
  /* color: #666666; */
}

.rules-title {
  font-weight: bold;
}

.scroll-hint {
  text-align: center;
  padding: 10rpx;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  background-color: #f9f9f9;
}

.table-container {
  overflow-x: auto;
  background-color: #fff;
}

.price-table {
  display: table;
  width: 100%;
  border-collapse: collapse;
  font-size: 22rpx;
}

/* 响应式调整 - 匹配H5端的媒体查询 */
@media (max-width: 375px) {
  .header-section {
    padding: 20rpx 24rpx;
  }
  .header-meta {
    font-size: 20rpx;
    margin-bottom: 16rpx;
  }
  .header-title {
    font-size: 32rpx;
    margin-bottom: 12rpx;
  }
  .header-info {
    font-size: 18rpx;
    padding: 12rpx;
    margin-bottom: 12rpx;
  }
  .header-rules {
    font-size: 16rpx;
  }
  .scroll-hint {
    font-size: 18rpx;
    padding: 8rpx;
  }
  .price-table {
    font-size: 20rpx;
  }
  .th {
    padding: 16rpx 10rpx;
    font-size: 20rpx;
    
  }
  .td {
    padding: 14rpx 6rpx;
    
  }
  .col-index {
    width: 50rpx;
    min-width: 50rpx;
    
    
  }
  .col-series {
    width: 140rpx;
    min-width: 140rpx;
  }
  .col-model {
    width: 120rpx;
    min-width: 120rpx;
  }
  .col-price {
    width: 100rpx;
    min-width: 100rpx;
  }
  .series-cell {
    font-size: 18rpx;
  }
  .model-cell {
    font-size: 18rpx;
  }
  .price-high, .price-mid, .price-low {
    font-size: 22rpx;
  }
  .price-normal {
    font-size: 20rpx;
  }
  .footer-note {
    padding: 24rpx;
    font-size: 18rpx;
  }
}

@media (max-width: 320px) {
  .header-section {
    padding: 16rpx 20rpx;
  }
  .header-meta {
    font-size: 18rpx;
    margin-bottom: 12rpx;
  }
  .header-title {
    font-size: 28rpx;
    margin-bottom: 10rpx;
  }
  .header-info {
    font-size: 16rpx;
    padding: 10rpx;
    margin-bottom: 10rpx;
  }
  .header-rules {
    font-size: 14rpx;
  }
  .scroll-hint {
    font-size: 16rpx;
    padding: 6rpx;
  }
  .price-table {
    font-size: 18rpx;
  }
  .th {
    padding: 14rpx 8rpx;
    font-size: 18rpx;
  }
  .td {
    padding: 12rpx 6rpx;
  }
  .col-index {
    width: 44rpx;
    min-width: 44rpx;
  }
  .col-series {
    width: 120rpx;
    min-width: 120rpx;
  }
  .col-model {
    width: 100rpx;
    min-width: 100rpx;
  }
  .col-price {
    width: 88rpx;
    min-width: 88rpx;
  }
  .series-cell {
    font-size: 16rpx;
  }
  .model-cell {
    font-size: 16rpx;
  }
  .price-high, .price-mid, .price-low {
    font-size: 20rpx;
  }
  .price-normal {
    font-size: 18rpx;
  }
  .footer-note {
    padding: 20rpx;
    font-size: 16rpx;
  }
}

.table-header {
  display: table-row;
  /* color: #666666;
  background-color: var(--color-primary); */
  background-color: #c0392b;
  color: #fff;
  padding: 10px 6px;
  text-align: center;
  font-weight: 600;
  border: 1px solid #a93226;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
}

.table-body {
  display: table-row-group;
}

.tr {
  display: table-row;
}

.th {
  display: table-cell;
  background-color: #c0392b;
  background-color: var(--color-primary);
  /* color: #666666; */
  padding: 20rpx 12rpx;
  text-align: center;
  font-weight: 600;
  border: 1rpx solid #a93226;
  border: 1rpx solid var(--color-primary-dark);
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 1;
}

.td {
  display: table-cell;
  padding: 16rpx 8rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  vertical-align: middle;
}

.col-index {
  width: 60rpx;
  min-width: 60rpx;
}

.col-series {
  width: 160rpx;
  min-width: 160rpx;
}

.col-model {
  width: 140rpx;
  min-width: 140rpx;
}

.col-price {
  width: 110rpx;
  min-width: 110rpx;
}

.series-cell {
  background-color: #fdf2f2;
  font-weight: 600;
  color: var(--color-primary);
  font-size: 20rpx;
}

.index-cell {
  background-color: #c0392b;
  color: #fff;
  padding: 10px 6px;
  text-align: center;
  font-weight: 600;
  border: 1px solid #a93226;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 10;
}

.model-cell {
  font-weight: 500;
  color: var(--color-text-primary);
  font-size: 20rpx;
}

.price-high {
  color: var(--color-price-high);
  font-weight: bold;
  font-size: 24rpx;
}

.price-mid {
  color: var(--color-price-mid);
  font-weight: bold;
  font-size: 24rpx;
}

.price-low {
  color: var(--color-price-low);
  font-weight: bold;
  font-size: 24rpx;
}

.price-normal {
  color: var(--color-text-primary);
  font-size: 22rpx;
}

.price-none {
  color: var(--color-text-tertiary);
}

.series-divider .td {
  border-top: 4rpx solid var(--color-primary);
}

.footer-note {
  padding: 30rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  background-color: #fff;
  margin-top: 20rpx;
}

.footer-note text {
  display: block;
  margin-bottom: 8rpx;
}

.note-title {
  font-weight: bold;
  color: var(--color-text-primary);
}

.quick-actions {
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 16rpx;
  color: #fff;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.trend-hint {
  font-size: 20rpx;
  margin-left: 8rpx;
  opacity: 0.7;
}

.tr {
  transition: background-color 0.2s;
}

.tr:active {
  background-color: #f0f8ff;
}


