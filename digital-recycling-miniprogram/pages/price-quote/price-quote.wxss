@import '/styles/design-tokens.wxss';

.price-quote-page {
  background-color: var(--color-background);
  font-size: 24rpx;
  color: var(--color-text-primary);
  padding-bottom: 200rpx;
}

.search-section {
  padding: 16rpx 24rpx;
  background: var(--color-background-white);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-background);
  border-radius: var(--radius-full);
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-bar input {
  flex: 1;
  font-size: var(--font-size-sm);
  height: 48rpx;
}

.header-section {
  background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);
  color: #fff;
  padding: 12px 15px;
}

.header-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  margin-bottom: 20rpx;
  opacity: 0.9;
  /* color: #666666; */
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.header-info {
  font-size: 20rpx;
  line-height: 1.6;
  opacity: 0.95;
  background: rgba(255, 255, 255, 0.1);
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.header-info text {
  display: block;
  /* color: #666666; */
}

.header-rules {
  font-size: 18rpx;
  line-height: 1.5;
  opacity: 0.9;
}

.header-rules text {
  display: block;
  margin-bottom: 4rpx;
  /* color: #666666; */
}

.rules-title {
  font-weight: bold;
}

.header-quota {
  text-align: center;
  margin-bottom: 12rpx;
}

.quota-text {
  display: inline-block;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  color: #fff;
}

.quota-text.vip {
  background: rgba(255, 215, 0, 0.4);
  font-weight: bold;
}

.scroll-hint {
  text-align: center;
  padding: 10rpx;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  background-color: #f9f9f9;
}

.category-section {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.category-title {
  background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  padding: 16rpx;
  letter-spacing: 2rpx;
}

.table-scroll-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  background-color: #fff;
}

.table-scroll-wrap::-webkit-scrollbar {
  height: 6rpx;
}

.table-scroll-wrap::-webkit-scrollbar-thumb {
  background-color: #ccc;
  border-radius: 3rpx;
}

.price-table {
  display: table;
  width: 100%;
  min-width: max-content;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 22rpx;
  table-layout: fixed;
}

/* 响应式调整 - 匹配H5端的媒体查询 */
@media (max-width: 375px) {
  .header-section {
    padding: 20rpx 24rpx;
  }
  .header-meta {
    font-size: 20rpx;
    margin-bottom: 16rpx;
  }
  .header-title {
    font-size: 32rpx;
    margin-bottom: 12rpx;
  }
  .header-info {
    font-size: 18rpx;
    padding: 12rpx;
    margin-bottom: 12rpx;
  }
  .header-rules {
    font-size: 16rpx;
  }
  .header-quota .quota-text {
    font-size: 18rpx;
    padding: 4rpx 14rpx;
  }
  .scroll-hint {
    font-size: 18rpx;
    padding: 8rpx;
  }
  .price-table {
    font-size: 18rpx;
  }
  .th {
    padding: 14rpx 8rpx;
    font-size: 16rpx;
    
  }
  .td {
    padding: 10rpx 6rpx;
    font-size: 16rpx;
  }
  .col-model {
    width: 100rpx;
    min-width: 100rpx;
  }
  .col-price {
    width: 70rpx;
    min-width: 70rpx;
  }
  .col-remark {
    width: 110rpx;
    min-width: 110rpx;
  }
  .series-cell {
    font-size: 16rpx;
  }
  .model-cell {
    font-size: 16rpx;
  }
  .price-high, .price-mid, .price-low {
    font-size: 18rpx;
  }
  .price-normal {
    font-size: 16rpx;
  }
  .footer-note {
    padding: 24rpx;
    font-size: 18rpx;
  }
}

@media (max-width: 320px) {
  .header-section {
    padding: 16rpx 20rpx;
  }
  .header-meta {
    font-size: 18rpx;
    margin-bottom: 12rpx;
  }
  .header-title {
    font-size: 28rpx;
    margin-bottom: 10rpx;
  }
  .header-info {
    font-size: 16rpx;
    padding: 10rpx;
    margin-bottom: 10rpx;
  }
  .header-rules {
    font-size: 14rpx;
  }
  .header-quota .quota-text {
    font-size: 16rpx;
    padding: 4rpx 12rpx;
  }
  .scroll-hint {
    font-size: 16rpx;
    padding: 6rpx;
  }
  .price-table {
    font-size: 16rpx;
  }
  .th {
    padding: 12rpx 6rpx;
    font-size: 14rpx;
  }
  .td {
    padding: 10rpx 4rpx;
    font-size: 14rpx;
  }
  .col-index {
    width: 40rpx;
    min-width: 40rpx;
  }
  .col-series {
    width: 110rpx;
    min-width: 110rpx;
  }
  .col-model {
    width: 90rpx;
    min-width: 90rpx;
  }
  .col-price {
    width: 66rpx;
    min-width: 66rpx;
  }
  .col-remark {
    width: 100rpx;
    min-width: 100rpx;
  }
  .series-cell {
    font-size: 14rpx;
  }
  .model-cell {
    font-size: 14rpx;
  }
  .price-high, .price-mid, .price-low {
    font-size: 16rpx;
  }
  .price-normal {
    font-size: 14rpx;
  }
  .footer-note {
    padding: 20rpx;
    font-size: 16rpx;
  }
}

.table-header {
  display: table-row;
  background-color: #c0392b;
  color: #fff;
  text-align: center;
  font-weight: 600;
  position: sticky;
  top: 0;
  z-index: 10;
}

.table-body {
  display: table-row-group;
}

.tr {
  display: table-row;
}

.th {
  display: table-cell;
  background-color: #c0392b;
  padding: 16rpx 4rpx;
  text-align: center;
  font-weight: 600;
  border: 1rpx solid #a93226;
  border: 1rpx solid var(--color-primary-dark);
  word-break: break-all;
  vertical-align: middle;
  position: sticky;
  top: 0;
  z-index: 1;
  font-size: 18rpx;
}

.td {
  display: table-cell;
  padding: 10rpx 4rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  vertical-align: middle;
  font-size: 18rpx;
}

.col-model {
  width: 100rpx;
  min-width: 100rpx;
}

.col-price {
  width: 70rpx;
  min-width: 70rpx;
}

.col-remark {
  width: 120rpx;
  min-width: 120rpx;
}

.th, .td {
  word-break: break-all;
}

.series-cell {
  background-color: #fdf2f2;
  font-weight: 600;
  color: var(--color-primary);
  font-size: 18rpx;
}

.model-cell {
  font-weight: 500;
  color: var(--color-text-primary);
  font-size: 18rpx;
}

.remark-cell {
  font-size: 16rpx;
  color: var(--color-text-secondary);
  text-align: left;
  padding: 10rpx 8rpx;
}

.price-high {
  color: var(--color-price-high);
  font-weight: bold;
  font-size: 20rpx;
}

.price-mid {
  color: var(--color-price-mid);
  font-weight: bold;
  font-size: 20rpx;
}

.price-low {
  color: var(--color-price-low);
  font-weight: bold;
  font-size: 20rpx;
}

.price-normal {
  color: var(--color-text-primary);
  font-size: 18rpx;
}

.price-none {
  color: var(--color-text-tertiary);
}

.series-divider .td {
  border-top: 4rpx solid var(--color-primary);
}

.footer-note {
  padding: 30rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  background-color: #fff;
  margin-top: 20rpx;
}

.footer-note text {
  display: block;
  margin-bottom: 8rpx;
}

.note-title {
  font-weight: bold;
  color: var(--color-text-primary);
}

.quick-actions {
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 16rpx;
  color: #fff;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.trend-hint {
  font-size: 20rpx;
  margin-left: 8rpx;
  opacity: 0.7;
}

.tr {
  transition: background-color 0.2s;
}

.tr:active {
  background-color: #f0f8ff;
}

/* Sticky left column */
.col-model {
  position: sticky;
  left: 0;
  z-index: 2;
  background-color: #fff;
}

.table-header .col-model {
  position: sticky;
  left: 0;
  z-index: 11;
  background-color: #c0392b;
  color: #fff;
}

/* Sub-table separator */
.sub-table {
  border-top: 3rpx solid var(--color-primary);
}

/* Loading mask */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* Fixed left panel for flex layout */
.sub-table-container {
  display: flex;
  border-bottom: 1rpx solid #ddd;
}

.has-divider {
  border-top: 3rpx solid var(--color-primary);
}

.fixed-col {
  position: sticky;
  left: 0;
  z-index: 2;
  background-color: #fff;
  flex-shrink: 0;
  width: 130rpx;
  border-right: 1rpx solid #ddd;
}

.scroll-col {
  flex: 1;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  min-width: 0;
}

/* Override table styles for flex panels */
.fixed-col .table-header,
.fixed-col .table-body,
.scroll-col .table-header,
.scroll-col .table-body {
  display: flex;
}

.fixed-col .table-body,
.scroll-col .table-body {
  flex-direction: column;
}

.fixed-col .th {
  position: sticky;
  left: 0;
  z-index: 3;
  background-color: #c0392b;
  color: #fff;
}

.scroll-col .th {
  background-color: #c0392b;
  color: #fff;
  flex-shrink: 0;
  width: 96rpx;
  min-width: 96rpx;
}

.scroll-col .th.col-remark {
  width: 160rpx;
  min-width: 160rpx;
}

.fixed-col .td {
  border-bottom: 1rpx solid #eee;
}

.scroll-col .td {
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
  width: 96rpx;
  min-width: 96rpx;
}

.scroll-col .td.col-remark {
  width: 160rpx;
  min-width: 160rpx;
}

/* Ensure sticky works correctly */
.fixed-col {
  position: sticky;
  left: 0;
  z-index: 2;
}


