<view class="price-quote-page">
  <!-- 搜索栏 -->
  <!-- <view class="search-section">
    <view class="search-bar">
      <image class="search-icon" src="/images/icons/search-gray.svg" mode="aspectFit"/>
      <input type="text" placeholder="搜索品牌或型号" confirm-type="search" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
  </view> -->

  <view class="header-section">
    <view class="header-meta">
      <text>浏览量：{{viewCount}}</text>
      <text>更新时间：{{updateTime}}</text>
    </view>
    <view class="header-quota">
      <block wx:if="{{isVip}}">
        <text class="quota-text vip">会员无限查看</text>
      </block>
      <block wx:elif="{{quoteRemaining > 0}}">
        <text class="quota-text">剩余免费次数：{{quoteRemaining}} 次</text>
      </block>
      <block wx:else>
        <text class="quota-text">今日剩余：{{quoteDailyRemaining}} 次</text>
      </block>
    </view>
    <view class="header-title">{{pageTitle}}</view>
    <!-- <view class="header-info">
      <text>收货地址：{{receiverAddress}}</text>
      <text>收件人：{{receiverName}}</text>
      <text>收款电话：{{receiverPhone}}（微信同号同步）</text>
    </view> -->
    <view class="header-rules">
      <text class="rules-title">回收标准释义：</text>
      <text>开机进系统/屏好/屏坏/不开机/废板 等机况定义说明...</text>
      <text>具体以实际检测为准，价格仅供参考</text>
    </view>
  </view>

  <!-- <view class="quick-actions">
    <view class="action-item" bindtap="goToStock">
      <text class="action-icon">📦</text>
      <text class="action-text">我的压货</text>
    </view>
    <view class="action-item" bindtap="goToMailingAddress">
      <text class="action-icon">📮</text>
      <text class="action-text">邮寄地址</text>
    </view>
  </view> -->

  <!-- Loading 遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <loading-spinner size="large" color="primary" text="加載中..." />
  </view>

  <block wx:if="{{!isEmpty}}">
    <block wx:for="{{categoryGroups}}" wx:for-item="category" wx:key="index">
      <view class="category-section">
        <block wx:for="{{category.seriesList}}" wx:for-item="series" wx:key="index">
          <block wx:for="{{series.subTables}}" wx:for-item="subTable" wx:key="index">
            <view class="table-scroll-wrap">
              <view class="price-table {{subTable.items.length > 1 ? 'sub-table' : ''}}">
                <view class="table-header">
                  <view class="th col-model">{{series.name}}</view>
                  <view class="th col-price" wx:for="{{subTable.visibleConditions}}" wx:for-item="cond" wx:key="id">{{cond.name}}</view>
                  <view class="th col-remark">备注</view>
                </view>
                <view class="table-body">
                  <block wx:for="{{subTable.items}}" wx:for-item="item" wx:key="index">
                    <view class="tr" bindtap="goToPriceTrend" data-product-id="{{item.productId}}" data-model="{{item.model}}">
                      <view class="td model-cell">
                        {{item.model}}
                        <text class="trend-hint">📈</text>
                      </view>
                      <view class="td {{price.cls}}" wx:for="{{item.prices}}" wx:for-item="price" wx:key="index">{{price.val}}</view>
                      <view class="td remark-cell">{{item.remark}}</view>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </block>
        </block>
      </view>
    </block>
  </block>

  <!-- 空状态 -->
  <empty-state wx:else title="暂无报价数据" desc="该品牌暂无报价信息" />

  <view class="footer-note">
    <text class="note-title">备注说明：</text>
    <text>1. 以上报价为当日回收参考价，实际价格以到货检测为准</text>
    <text>2. 绿色为开机屏好回收价，黑色为不开机/废板回收价，蓝色为其余机况回收价</text>
    <text>3. "/" 表示该机型此状态暂不回收或无报价</text>
    <text>4. 废板整机指主板损坏无法开机的完整机器</text>
    <text>5. 价格随市场行情波动，请以实际交易为准</text>
  </view>

  <!-- 自定义TabBar -->
  <custom-tabbar activeTab="priceList" />
</view>
