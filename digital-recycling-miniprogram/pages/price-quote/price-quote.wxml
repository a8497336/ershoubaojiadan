<view class="price-quote-page">
  <!-- 搜索栏 -->
  <!-- <view class="search-section">
    <view class="search-bar">
      <image class="search-icon" src="/images/icons/search-gray.svg" mode="aspectFit"/>
      <input type="text" placeholder="搜索品牌或型号" confirm-type="search" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    </view>
  </view> -->

  <view class="header-section">
    <view class="header-meta">
      <text>浏览量：{{viewCount}}</text>
      <text>更新时间：{{updateTime}}</text>
    </view>
    <view class="header-title">{{brand ? brand + '回收报价' : (category ? category + '回收报价' : '今日回收报价')}}</view>
    <view class="header-info">
      <text>收货地址：{{receiverAddress}}</text>
      <text>收件人：{{receiverName}}</text>
      <text>收款电话：{{receiverPhone}}（微信同号同步）</text>
    </view>
    <view class="header-rules">
      <text class="rules-title">回收标准释义：</text>
      <text>开机进系统/屏好/屏坏/不开机/废板 等机况定义说明...</text>
      <text>具体以实际检测为准，价格仅供参考</text>
    </view>
  </view>

  <!-- <view class="quick-actions">
    <view class="action-item" bindtap="goToStock">
      <text class="action-icon">📦</text>
      <text class="action-text">我的压货</text>
    </view>
    <view class="action-item" bindtap="goToMailingAddress">
      <text class="action-icon">📮</text>
      <text class="action-text">邮寄地址</text>
    </view>
  </view> -->

  <block wx:if="{{!isEmpty}}">
    <view class="table-container">
      <view class="price-table">
        <view class="table-header">
          <view class="th col-model">型号</view>
          <view class="th col-price" wx:for="{{conditions}}" wx:key="id">{{item.name}}</view>
        </view>
        <view class="table-body">
          <block wx:for="{{seriesList}}" wx:for-item="series" wx:key="index">
            <block wx:for="{{series.items}}" wx:for-item="item" wx:key="index">
              <view class="tr {{index === 0 && series.index > 1 ? 'series-divider' : ''}}" bindtap="goToPriceTrend" data-product-id="{{item.productId}}" data-model="{{item.model}}">
                <view class="td model-cell">
                  {{item.model}}
                  <text class="trend-hint">📈</text>
                </view>
                <view class="td {{price.cls}}" wx:for="{{item.prices}}" wx:for-item="price" wx:key="index">{{price.val}}</view>
              </view>
            </block>
          </block>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <empty-state wx:else title="暂无报价数据" desc="该品牌暂无报价信息" />

  <view class="footer-note">
    <text class="note-title">备注说明：</text>
    <text>1. 以上报价为当日回收参考价，实际价格以到货检测为准</text>
    <text>2. 绿色价格为高价回收，蓝色为中价，紫色为低价</text>
    <text>3. "/" 表示该机型此状态暂不回收或无报价</text>
    <text>4. 废板整机指主板损坏无法开机的完整机器</text>
    <text>5. 价格随市场行情波动，请以实际交易为准</text>
  </view>

  <!-- 自定义TabBar -->
  <custom-tabbar activeTab="priceList" />
</view>
