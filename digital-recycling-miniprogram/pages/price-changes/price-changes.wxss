@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.list-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.change-item { background: var(--color-background-white); border-radius: var(--radius-lg); padding: 24rpx; box-shadow: var(--shadow-sm); }
.change-item:active { background: var(--card-active-bg); }
.ch-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.ch-name { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: var(--font-weight-medium); }
.ch-change { font-size: var(--font-size-md); font-weight: var(--font-weight-semibold); }
.ch-change.up { color: var(--color-success); }
.ch-change.down { color: var(--color-error); }
.ch-bottom { display: flex; justify-content: space-between; align-items: center; }
.ch-price { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.ch-time { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
.empty-wrap { padding: 80rpx 0; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
