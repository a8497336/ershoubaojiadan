@import '/styles/design-tokens.wxss';

.my-stock-page {
  background-color: var(--color-background);
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.header-card {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 30rpx;
}

.action-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.sort-btn,
.filter-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.sort-icon,
.filter-icon {
  margin-left: 8rpx;
  font-size: 20rpx;
}

.stock-list {
  padding: 0 30rpx;
}

.stock-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stock-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.stock-info {
  flex: 1;
}

.stock-brand {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.stock-model {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stock-change {
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.stock-change.up {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.stock-change.down {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.stock-details {
  display: flex;
  gap: 30rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.detail-item {
  flex: 1;
  text-align: center;
}

.detail-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.detail-value.price-high {
  color: var(--color-primary);
  font-weight: bold;
}

.stock-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stock-action {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.stock-action.primary {
  background: var(--color-primary);
  color: #fff;
}

.stock-action.secondary {
  background: #f0f8ff;
  color: var(--color-primary);
}

.stock-action.delete {
  background: #fff1f0;
  color: #ff4d4f;
}

.stock-note {
  padding: 16rpx;
  background: #fffef0;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.stock-time {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.empty-container {
  padding: 120rpx 30rpx;
  text-align: center;
}

.add-stock-btn {
  margin-top: 40rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  font-size: 28rpx;
}

.loading-container {
  padding: 60rpx 30rpx;
}

.float-add {
  position: fixed;
  right: 30rpx;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-primary);
  color: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 74, 0.3);
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 4rpx;
}

.float-add text:nth-child(2) {
  font-size: 22rpx;
}
