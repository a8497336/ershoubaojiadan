@import '/styles/design-tokens.wxss';

.shopping-page {
  background-color: var(--color-background);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.page-header {
  background: var(--color-background-white);
  text-align: center;
  padding: 32rpx;
  position: sticky;
  top: 0;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.top-stat {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.stat-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

.stat-label {
  color: var(--color-text-tertiary);
}

.stat-num {
  color: var(--color-primary);
  font-weight: 600;
  margin: 0 4rpx;
}

.stat-num.highlight {
  color: var(--color-primary);
}

.clear-btn {
  background: none;
  border: none;
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 500;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin: 0;
  line-height: 1;
}

.clear-btn::after {
  border: none;
}

.category-section {
  background: #fff;
  margin-bottom: 16rpx;
}

.category-title-wrap {
  background: #fff;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.category-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-icon {
  font-size: 48rpx;
}

.category-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.clear-category-btn {
  background: var(--color-background);
  border: none;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  margin: 0;
  line-height: 1;
}

.clear-category-btn::after {
  border: none;
}

.cat-tag {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-background-gray);
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  color: var(--color-text-tertiary);
  margin: 0;
}

.tag-icon {
  font-size: 36rpx;
}

.product-list {
  background: #fff;
}

.product-item {
  background: #fff;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.product-item.is-selected {
  background: #fff9f9;
}

.item-wrapper {
  padding: 40rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.checkbox-round {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  flex-shrink: 0;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 32rpx;
  transition: all 0.3s ease;
  border: 2rpx solid #e0e0e0;
}

.checkbox-round.is-checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.product-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.product-brand,
.product-condition {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  background: var(--color-background);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.product-price {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price-label {
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.price-red {
  color: var(--color-primary);
  font-size: 40rpx;
  font-weight: 800;
}

.item-actions {
  padding: 32rpx 40rpx;
  padding-top: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md, 16rpx);
  border: none;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background: #fff;
  color: var(--color-text-primary);
  line-height: 1;
}

.qty-btn::after {
  border: none;
}

.qty-btn[disabled] {
  opacity: 0.3;
  background: #e0e0e0 !important;
  color: #bbb !important;
}

.qty-plus {
  background: var(--color-primary-gradient);
  color: #fff;
}

.qty-input {
  width: 80rpx;
  height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  border: none;
  background: transparent;
}

.delete-btn {
  width: 88rpx;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid var(--color-border-light);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  padding: 0;
  margin: 0;
}

.delete-btn::after {
  border: none;
}

.tip-text {
  padding: 32rpx 40rpx;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
}

.tip-icon {
  font-size: 36rpx;
}

.bottom-settle-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 98;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.select-all-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  margin: -16rpx;
}

.settle-checkbox {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: bold;
  font-size: 32rpx;
  transition: all 0.3s ease;
  border: 2rpx solid #e0e0e0;
}

.settle-checkbox.is-checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.select-all-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.total-section {
  flex: 1;
  text-align: center;
}

.total-text {
  font-size: 32rpx;
  color: var(--color-text-primary);
}

.total-price {
  color: var(--color-primary);
  font-size: 48rpx;
  font-weight: 800;
}

.total-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.btn-add-more {
  padding: 20rpx 36rpx;
  border-radius: 40rpx;
  border: none;
  background: linear-gradient(145deg, var(--color-warning), #ff8800);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 153, 51, 0.3);
  white-space: nowrap;
  margin: 0;
  line-height: 1;
}

.btn-add-more::after {
  border: none;
}

.btn-submit {
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  border: none;
  background: var(--color-primary-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 43, 64, 0.3);
  white-space: nowrap;
  margin: 0;
  line-height: 1;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  max-width: 640rpx;
  width: 100%;
}

.modal-icon {
  font-size: 128rpx;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.modal-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  line-height: 1;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: var(--color-background);
  color: var(--color-text-secondary);
}

.modal-btn.confirm {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 51, 68, 0.3);
}
