@import '/styles/design-tokens.wxss';

.cart-page {
  background: var(--color-background);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.nav-bar {
  background: var(--color-primary);
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: sticky;
  z-index: 100;
  box-shadow: var(--shadow-sm);
}
.title-text { color: var(--color-text-primary); font-size: var(--font-size-lg); font-weight: var(--font-weight-medium); }

.stats-bar {
  background: var(--color-background-white);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--color-border-light);
}
.stat-label { font-size: 26rpx; color: var(--color-text-tertiary); }
.stat-num { font-size: 26rpx; color: var(--color-primary); font-weight: var(--font-weight-semibold); margin: 0 4rpx; }
.stat-num.highlight { font-size: 30rpx; }

.category-header {
  background: var(--color-background-white);
  padding: 20rpx 24rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid var(--color-border-light);
}
.category-left { display: flex; align-items: center; gap: 12rpx; font-size: 32rpx; }
.clear-category-btn {
  background: var(--color-background);
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
}

.cart-list { background: var(--color-background-white); }

.cart-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-background);
}
.cart-item.selected { background: var(--color-primary-light); }

.cart-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--color-border);
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cart-checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
.cart-checkbox.checked::after {
  content: '✓';
  color: var(--color-text-inverse);
  font-size: 24rpx;
}

.cart-item-info { flex: 1; min-width: 0; }
.ci-name { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: var(--font-weight-medium); }
.ci-grade { font-size: var(--font-size-xs); color: var(--color-text-tertiary); margin-top: 4rpx; }
.ci-price { margin-top: 6rpx; display: flex; align-items: baseline; }
.price-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.price-red { color: var(--color-primary); font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); }

.qty-ctrl { display: flex; align-items: center; gap: 12rpx; margin-right: 12rpx; }
.qty-btn {
  width: 48rpx; height: 48rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-size-md); color: var(--color-text-secondary); background: var(--color-background-white);
}
.qty-num { font-size: var(--font-size-base); color: var(--color-text-primary); min-width: 48rpx; text-align: center; }

.delete-btn {
  width: 44rpx; height: 44rpx;
  background: var(--color-background);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.tip-text {
  padding: 20rpx 24rpx;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-background-white);
}

.settle-bar {
  position: fixed;
  bottom: 230rpx;
  left: 0;
  right: 0;
  background: var(--color-background-white);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 50;
}
.select-all { display: flex; align-items: center; gap: 12rpx; margin-right: 16rpx; }
.select-all .cart-checkbox { margin-right: 0; }
.select-all text { font-size: 26rpx; color: var(--color-text-secondary); }

.total-section { flex: 1; text-align: center; }
.total-text { font-size: var(--font-size-base); color: var(--color-text-primary); }
.total-text .price { color: var(--color-primary); font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); }
.total-hint { font-size: var(--font-size-xs); color: var(--color-text-tertiary); margin-top: 2rpx; }

.add-more-btn {
  background: var(--color-warning);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--radius-full);
  padding: 16rpx 28rpx;
  font-size: var(--font-size-base);
  margin-right: 16rpx;
}

.submit-btn {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--radius-full);
  padding: 16rpx 28rpx;
  font-size: var(--font-size-base);
}
.submit-btn[disabled] { opacity: 0.5; }

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-bg-mask);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}
.modal-box {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  width: 600rpx;
  padding: 48rpx 32rpx 32rpx;
}
.modal-icon-text { font-size: 64rpx; display: block; text-align: center; margin-bottom: 24rpx; opacity: 0.6; }
.modal-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 40rpx;
}
.modal-btns { display: flex; gap: 24rpx; }
.modal-btns button {
  flex: 1;
  border: none;
  border-radius: var(--radius-full);
  padding: 24rpx 0;
  font-size: var(--font-size-base);
}
.modal-btns .cancel { background: var(--color-background); color: var(--color-text-secondary); }
.modal-btns .confirm { background: var(--color-primary); color: var(--color-text-inverse); }

.full-loading { display: flex; justify-content: center; align-items: center; height: 600rpx; }
