@import '/styles/design-tokens.wxss';

.page-container {
  min-height: 100vh;
  background: var(--color-background);
  padding-bottom: 40rpx;
}

.balance-card {
  margin: 24rpx;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-primary);
}
.balance-label {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
}
.balance-value {
  font-size: var(--font-size-4xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-inverse);
  margin-bottom: 32rpx;
}
.log-header {
  padding: 24rpx 24rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.log-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.log-list {
  margin: 0 24rpx;
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}
.log-item:last-child { border-bottom: none; }
.log-item:active { background: var(--card-active-bg); }
.log-left { flex: 1; }
.log-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 6rpx;
}
.log-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.log-right { text-align: right; }
.log-amount {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-error);
  display: block;
  margin-bottom: 4rpx;
}
.log-amount.income { color: var(--color-success); }
.log-after {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
}
.error-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}
.error-title {
  font-size: var(--font-size-xl);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-bold);
  margin-bottom: 12rpx;
}
.error-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}
.empty-img {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}
.no-more {
  text-align: center;
  padding: 32rpx;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
