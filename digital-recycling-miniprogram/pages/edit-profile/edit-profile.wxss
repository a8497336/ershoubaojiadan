@import '/styles/design-tokens.wxss';

.edit-profile-page {
  background: var(--color-background);
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

/* ===== 提示卡片 ===== */
.tip-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
}
.tip-card.warn {
  background: linear-gradient(135deg, #fff8e1, #fff3c0);
  border: 1rpx solid rgba(255, 193, 7, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.15);
}
.tip-card.done {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border: 1rpx solid rgba(76, 175, 80, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.15);
}
.tip-emoji { font-size: 44rpx; }
.tip-body { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.tip-card.warn .tip-title { color: #f57c00; }
.tip-card.warn .tip-desc { color: #ff9800; }
.tip-card.done .tip-title { color: #2e7d32; }
.tip-card.done .tip-desc { color: #4caf50; }
.tip-title { font-size: 30rpx; font-weight: 600; }
.tip-desc { font-size: 24rpx; }

/* ===== 卡片通用 ===== */
.card {
  background: #fff;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-sm);
}
.card-title {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 20rpx;
}

/* ===== 头像行 ===== */
.avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  margin: 0;
  padding: 0;
  line-height: 1.4;
  font-size: inherit;
  color: inherit;
  text-align: left;
}
.avatar-row::after { border: none; }
.avatar-row:active { opacity: 0.7; }
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-background-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border-light);
}
.avatar-preview image { width: 100%; height: 100%; }
.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b, #ff8e53);
}
.placeholder-text { font-size: 48rpx; color: #fff; font-weight: 600; }

/* ===== 行通用 ===== */
.row-meta { display: flex; align-items: center; gap: 8rpx; }

/* ===== 状态标签 ===== */
.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-tag.done { color: #4caf50; background: rgba(76, 175, 80, 0.1); }
.status-tag.todo { color: #ff9800; background: rgba(255, 152, 0, 0.1); }

/* ===== 箭头 ===== */
.arrow { font-size: 36rpx; color: var(--color-text-tertiary); }

/* ===== 昵称行 ===== */
.nickname-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: var(--color-text-primary);
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-border-light);
}

/* ===== 手机号行 ===== */
.phone-row, .phone-bind-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.phone-bind-row {
  background: transparent;
  margin: 0;
  padding: 0;
  line-height: 1.4;
  font-size: inherit;
  color: inherit;
  text-align: left;
}
.phone-bind-row::after { border: none; }
.phone-value { font-size: 34rpx; color: var(--color-text-primary); font-weight: 500; }
.phone-placeholder { font-size: 30rpx; color: var(--color-text-tertiary); }
.bind-btn {
  background: var(--color-primary);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 40rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

/* ===== 温馨提示 ===== */
.tips-section {
  margin-top: 16rpx;
  padding: 24rpx 32rpx;
}
.tips-title {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 600;
  margin-bottom: 12rpx;
}
.tips-item {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.8;
}
