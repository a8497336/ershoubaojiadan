@import '/styles/design-tokens.wxss';

.search-page {
  background: #f5f5f5;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #fff;
}
.search-input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #eee;
}
.search-input-box .s-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}
.search-input-box input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  background: transparent;
}
.search-btn {
  background: #ff2d4a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
}
.search-btn:active { background: #e62540; }

.results-scroll {
  flex: 1;
  padding: 0 12rpx;
  padding-bottom: 50rpx;
  overflow-y: auto;
}

.product-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 12rpx;
  padding-right: 30px;
  border-bottom: 1rpx solid #f5f5f5;
}
.product-card:active { background: #f9f9f9; }

.product-info { flex: 1; }
.product-info .p-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.search-brand-title {
  font-size: 26rpx;
  font-weight: 500;
  padding: 16rpx 20rpx 6rpx;
  color: #ff2d4a;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.modal-panel {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx 24rpx 250rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #333; }
.modal-close { font-size: 40rpx; color: #999; padding: 8rpx; }

.modal-image-area {
  width: 100%;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 100rpx;
}
.modal-image-area image { width: 100%; height: 100%; border-radius: 16rpx; }

.trend-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border: 2rpx solid #ff2d4a;
  border-radius: 48rpx;
  color: #ff2d4a;
  font-size: 28rpx;
  font-weight: 500;
}
.trend-btn:active {
  background: #fff5f6;
}

.condition-section { margin-bottom: 24rpx; }
.condition-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.condition-list { max-height: 480rpx; overflow-y: auto; }
.condition-empty { display: flex; justify-content: center; padding: 32rpx 0; }

.condition-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.condition-price-row:last-child { border-bottom: none; }

.condition-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  min-width: 0;
}

.condition-price {
  font-size: 30rpx;
  color: #ff2d4a;
  font-weight: bold;
  margin: 0 24rpx;
  min-width: 100rpx;
  text-align: right;
}
.condition-price.zero {
  color: #ccc;
  font-weight: normal;
}

.condition-qty-ctrl {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  background: #fff;
}
.qty-btn:active { background: #f0f0f0; }
.qty-btn.disabled { opacity: 0.3; }

.qty-num { font-size: 36rpx; color: #333; font-weight: 600; min-width: 60rpx; text-align: center; }

.add-cart-btn {
  width: 100%;
  background: #ff2d4a;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}
.add-cart-btn:active { background: #e62540; }
