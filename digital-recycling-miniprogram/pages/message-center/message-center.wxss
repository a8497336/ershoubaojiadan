@import '/styles/design-tokens.wxss';

.message-center-page {
  min-height: 100vh;
  background: var(--color-background);
}

/* 顶部操作栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-2) var(--space-3);
  background: var(--color-background-white);
  border-bottom: 1rpx solid var(--color-border-light);
}

.unread-info {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.mark-all-btn {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: var(--space-1) var(--space-2);
}

/* 分类Tab */
.type-tabs {
  display: flex;
  background: var(--color-background-white);
  padding: 0 var(--space-3);
  border-bottom: 1rpx solid var(--color-border-light);
}

.type-tabs .tab-item {
  flex: 1;
  text-align: center;
  padding: var(--space-3) 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  position: relative;
  transition: color var(--transition-fast);
}

.type-tabs .tab-item.active {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.type-tabs .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: var(--radius-sm);
}

/* 消息列表 */
.message-list {
  padding: var(--space-2) var(--space-3);
}

.message-item {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-3);
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-2);
  transition: background var(--transition-fast);
}

.message-item.unread {
  background: linear-gradient(90deg, var(--color-error-light) 0%, var(--color-background-white) 100%);
}

.message-item:active {
  background: var(--color-background-gray);
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.message-icon image {
  width: 40rpx;
  height: 40rpx;
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-1);
}

.message-title-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  flex: 1;
  min-width: 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  flex-shrink: 0;
}

.message-title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-tag {
  font-size: var(--font-size-xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.message-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  margin-left: var(--space-2);
}

.message-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 骨架屏 */
.loading-state {
  padding: var(--space-3);
}

.skeleton-item {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-3);
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-2);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--color-border);
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
}

.skeleton-line {
  height: 28rpx;
  background: var(--color-border);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-2);
}

.skeleton-line.title {
  width: 60%;
  height: 32rpx;
}