@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.list-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.packet-item {
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(135deg, #ff4444 0%, #ff6666 100%);
  border-radius: var(--radius-lg); padding: 36rpx 28rpx; color: var(--color-text-inverse); box-shadow: var(--shadow-md);
}
.packet-item:active { opacity: 0.9; }
.packet-left { display: flex; flex-direction: column; gap: 8rpx; }
.packet-amount { font-size: var(--font-size-2xl); font-weight: var(--font-weight-bold); }
.packet-from { font-size: var(--font-size-xs); opacity: 0.8; }
.packet-right { text-align: right; display: flex; flex-direction: column; gap: 8rpx; }
.packet-status { font-size: var(--font-size-base); font-weight: var(--font-weight-medium); }
.packet-status.done { opacity: 0.7; }
.packet-time { font-size: var(--font-size-xs); opacity: 0.7; }
.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
.empty-wrap { padding: 80rpx 0; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
