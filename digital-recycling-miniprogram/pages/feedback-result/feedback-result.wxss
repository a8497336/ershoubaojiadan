@import '/styles/design-tokens.wxss';
.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }
.list-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.feedback-item { background: var(--color-background-white); border-radius: var(--radius-lg); padding: 24rpx; box-shadow: var(--shadow-sm); }
.fb-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12rpx; }
.fb-title { font-size: var(--font-size-base); color: var(--color-text-primary); font-weight: var(--font-weight-medium); flex: 1; }
.fb-status { font-size: var(--font-size-xs); color: var(--color-warning); background: var(--color-warning-light); padding: 4rpx 12rpx; border-radius: var(--radius-sm); white-space: nowrap; margin-left: 16rpx; }
.fb-status.done { color: var(--color-success); background: var(--color-success-light); }
.fb-time { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.fb-reply { font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid var(--color-border-light); }
.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }
.empty-wrap { padding: 80rpx 0; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
