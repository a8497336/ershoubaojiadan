<view class="order-list-page">
  <view class="status-tabs">
    <view class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}" wx:key="key"
      bindtap="switchTab" data-key="{{item.key}}">
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{loading && filteredOrders.length === 0}}">
    <loading-skeleton type="list" rowCount="3" showAvatar="{{false}}" />
  </view>

  <view wx:if="{{networkError && !loading}}" class="error-state" bindtap="onRetry">
    <image class="error-img" src="/images/icons/empty.svg" mode="aspectFit" />
    <text class="error-title">网络连接失败</text>
    <text class="error-desc">点击重新加载</text>
  </view>

  <block wx:if="{{!loading && !networkError}}">
    <view wx:if="{{filteredOrders.length > 0}}" class="order-list">
      <view class="order-card animate-slide-up" wx:for="{{filteredOrders}}" wx:key="id"
        bindtap="goToDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="order-id">订单号：{{item.id}}</text>
          <view class="status-badge" style="color: {{item.statusInfo.color}}">{{item.statusInfo.text}}</view>
        </view>

        <view class="order-items">
          <view class="item-row" wx:for="{{item.items}}" wx:for-item="product" wx:key="index">
            <view class="item-info">
              <text class="item-name">{{product.name}}</text>
              <text class="item-condition">{{product.condition}}</text>
            </view>
            <view class="item-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{product.price}}</text>
              <text class="price-unit">/ {{product.quantity}}台</text>
            </view>
          </view>
        </view>

        <view class="order-footer">
          <text class="order-time">{{item.createTime}}</text>
          <view class="order-total">
            <text class="total-label">合计：</text>
            <text class="total-price">¥{{item.totalAmountText}}</text>
          </view>
        </view>

        <view class="order-actions" wx:if="{{item.status === 'shipping'}}">
          <button class="btn-outline btn-sm" catchtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
        </view>
      </view>
    </view>

    <view wx:if="{{filteredOrders.length === 0}}" class="empty-wrap">
      <empty-state
        title="暂无订单"
        desc="您还没有相关状态的订单"
        showBtn="{{true}}"
        btnText="去回收"
        bind:btnTap="goHome"
      />
    </view>

    <view wx:if="{{loading && filteredOrders.length > 0}}" class="load-more">
      <loading-spinner size="small" />
    </view>
    <view wx:if="{{!hasMore && filteredOrders.length > 0}}" class="no-more">— 已经到底了 —</view>
  </block>
</view>
