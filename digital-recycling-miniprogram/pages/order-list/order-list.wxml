<view class="order-list-page">
  <!-- 状态筛选Tab -->
  <view class="status-tabs">
    <view 
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="switchTab"
      data-key="{{item.key}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:if="{{!isLoading && filteredOrders.length > 0}}">
      <view 
        class="order-card"
        wx:for="{{filteredOrders}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <!-- 订单头部 -->
        <view class="order-header">
          <text class="order-id">订单号：{{item.id}}</text>
          <view class="status-badge" style="color: {{item.statusInfo.color}}">
            {{item.statusInfo.text}}
          </view>
        </view>

        <!-- 商品信息 -->
        <view class="order-items">
          <view class="item-row" wx:for="{{item.items}}" wx:for-item="product" wx:key="index">
            <view class="item-info">
              <text class="item-name">{{product.name}}</text>
              <text class="item-condition">{{product.condition}}</text>
            </view>
            <view class="item-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{product.price}}</text>
              <text class="price-unit">/ {{product.quantity}}台</text>
            </view>
          </view>
        </view>

        <!-- 订单底部 -->
        <view class="order-footer">
          <text class="order-time">{{item.createTime}}</text>
          <view class="order-total">
            <text class="total-label">合计：</text>
            <text class="total-price">¥{{item.totalAmountText}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="order-actions" wx:if="{{item.status === 'shipping'}}">
          <button class="btn btn-outline btn-sm" catchtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
          <button class="btn btn-primary btn-sm" catchtap="viewLogistics" data-id="{{item.id}}">查看物流</button>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="skeleton-card" wx:for="{{3}}" wx:key="index">
        <view class="skeleton-line title"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line short"></view>
      </view>
    </view>

    <!-- 空状态 -->
    <empty-state 
      wx:if="{{!isLoading && filteredOrders.length === 0}}"
      title="暂无订单"
      desc="您还没有相关状态的订单"
      show-btn="true"
      btn-text="去回收"
      bind:btnTap="goHome"
    />
  </view>
</view>
