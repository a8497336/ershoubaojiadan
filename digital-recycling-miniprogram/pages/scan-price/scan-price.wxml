<view class="page-container">
  <!-- 主要内容区 -->
  <view class="main-red-section">
    <text class="main-title">拍照片 查价格</text>

    <view class="count-bar">
      <view class="count-item">
        <text class="num">{{points}} 分</text>
        <text class="label">拥有积分</text>
      </view>
      <view class="count-divider"></view>
      <view class="count-item">
        <text class="num">{{remainingTimes}} 次</text>
        <text class="label">剩余次数</text>
      </view>
    </view>

    <!-- 拍照按钮区域 -->
    <view class="click-wrap" bindtap="handleTakePhoto">
      <view class="corner-mark corner-tl"></view>
      <view class="corner-mark corner-tr"></view>
      <view class="corner-mark corner-bl"></view>
      <view class="corner-mark corner-br"></view>

      <view class="click-circle">
        <image class="camera-icon-img" src="/images/icons/camera.svg" mode="aspectFit"/>
        <text class="click-text">点击\n拍照查价</text>
      </view>
      <image class="hand-icon" src="/images/icons/hand.svg" mode="aspectFit"/>
    </view>

    <view class="digital-tag">数码</view>
  </view>

  <!-- 提示文字 -->
  <view class="tip-text">
    请尽量拍摄<text class="highlight">手机背面</text>，特征明显的一面
  </view>

  <!-- 识别结果 -->
  <view wx:if="{{showResult}}" class="result-section">
    <view class="result-header">
      <text class="result-title">识别结果</text>
      <text class="result-close" bindtap="closeResult">关闭</text>
    </view>

    <view wx:if="{{scanResult}}" class="result-image-wrap">
      <image class="result-image" src="{{scanResult.filePath || scanResult.image}}" mode="aspectFit" />
    </view>

    <view wx:if="{{matchedProducts.length > 0}}" class="matched-list">
      <view
        wx:for="{{matchedProducts}}"
        wx:key="id"
        class="matched-item"
        data-id="{{item.id}}"
        bindtap="goToProductDetail"
      >
        <view class="matched-info">
          <view class="matched-name">{{item.model || item.name}}</view>
          <view class="matched-brand" wx:if="{{item.Brand && item.Brand.name}}">{{item.Brand.name}}</view>
        </view>
        <view class="matched-price" wx:if="{{item.Prices && item.Prices.length > 0}}">
          ¥{{item.Prices[0].price}}
        </view>
        <view class="matched-arrow">></view>
      </view>
    </view>

    <view wx:else class="no-match">
      <view class="no-match-icon">🔍</view>
      <view class="no-match-text">未识别到匹配产品</view>
      <view class="no-match-action" bindtap="goToSearch">手动搜索</view>
    </view>
  </view>

  <!-- 扫描历史 -->
  <view wx:if="{{scanHistory.length > 0 && !showResult}}" class="history-section">
    <view class="history-title">最近扫描</view>
    <view class="history-list">
      <view
        wx:for="{{scanHistory}}"
        wx:key="time"
        class="history-item"
        data-id="{{item.id}}"
        bindtap="goToProductDetail"
      >
        <view class="history-info">
          <view class="history-name">{{item.name}}</view>
          <view class="history-brand" wx:if="{{item.brand}}">{{item.brand}}</view>
        </view>
        <view class="history-price" wx:if="{{item.price}}">¥{{item.price}}</view>
      </view>
    </view>
  </view>

  <!-- 加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在识别中...</text>
    </view>
  </view>

  <!-- 示例对比 -->
  <view class="compare-section">
    <text class="compare-title">拍摄示例</text>
    <view class="compare-row">
      <view class="compare-card card-correct">
        <view class="card-image-wrapper">
          <image class="phone-preview" src="/images/examples/correct.svg" mode="aspectFill"/>
          <view class="overlay-correct"></view>
        </view>
        <view class="card-bottom correct-bottom">
          <text class="check-circle">✓</text>
          <text class="card-text">正确（更快识别）</text>
        </view>
      </view>
      <view class="compare-card card-wrong">
        <view class="card-image-wrapper">
          <image class="phone-preview" src="/images/examples/wrong.svg" mode="aspectFill"/>
          <view class="overlay-wrong"></view>
        </view>
        <view class="card-bottom wrong-bottom">
          <text class="check-circle">×</text>
          <text class="card-text">错误（不易识别）</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部功能按钮 -->
  <!-- <view class="bottom-actions">
    <button class="action-btn secondary-btn">
      <image class="btn-icon-img" src="/images/icons/search.svg" mode="aspectFit"/> 查看历史
    </button>
    <button class="action-btn primary-btn">
      <image class="btn-icon-img" src="/images/icons/faq.svg" mode="aspectFit"/> 帮助中心
    </button>
  </view> -->

  <!-- 自定义TabBar -->
  <custom-tabbar activeTab="scanPrice" />
</view>
