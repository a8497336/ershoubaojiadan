@import '/styles/design-tokens.wxss';

.page-container {
  background-color: var(--color-background-gray);
  min-height: 100vh;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.main-red-section {
  background: linear-gradient(180deg, #ff2b3b 0%, #ff4754 100%);
  padding-top: 30px;
  padding-left: 20px;
  padding-right: 20px;
  padding-bottom: 60px;
  border-radius: 0 0 40% 40% / 0 0 12% 12%;
  position: relative;
}

.main-title {
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 36rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 2rpx;
  width: 100%;
}

.count-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.count-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.count-item {
  flex: 1;
  text-align: center;
}

.count-item .num {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.count-item .label {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

.click-wrap {
  background: #fff;
  border-radius: 24px;
  padding: 40px 24px;
  position: relative;
  text-align: center;
  box-shadow: 0 8px 32px rgba(255, 43, 59, 0.2);
  transition: transform 0.3s ease;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}

.click-wrap:active {
  transform: scale(0.98);
}

.corner-mark {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-primary);
}

.corner-tl {
  top: 40rpx;
  left: 40rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 16rpx 0 0 0;
}

.corner-tr {
  top: 40rpx;
  right: 40rpx;
  border-left: none;
  border-bottom: none;
  border-radius: 0 16rpx 0 0;
}

.corner-bl {
  bottom: 40rpx;
  left: 40rpx;
  border-right: none;
  border-top: none;
  border-radius: 0 0 0 16rpx;
}

.corner-br {
  bottom: 40rpx;
  right: 40rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 16rpx 0;
}

.click-circle {
  width: 180px;
  height: 180px;
  margin: 0 auto;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffecee, #fff);
  border: 8px solid #ff2b3b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8px 24px rgba(255, 43, 59, 0.3);
  transition: all 0.3s ease;
}

.dashed-ring {
  position: absolute;
  width: 210px;
  height: 210px;
  border: 3px dashed #ff999f;
  border-radius: 50%;
  opacity: 0.6;
  animation: rotateRing 20s linear infinite;
  pointer-events: none;
}

@keyframes rotateRing {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.camera-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.camera-icon-img {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.click-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.4;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.hand-icon {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  width: 200rpx;
  height: 200rpx;
}

.digital-tag {
  width: 144rpx;
  height: 144rpx;
  background: linear-gradient(145deg, #fff, #f0f0f0);
  border-radius: 50%;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -72rpx auto 0;
  font-size: 36rpx;
  font-weight: 800;
  z-index: 10;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tip-text {
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 64rpx 40rpx;
  line-height: 1.6;
  background: #fff;
  margin: 0 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
  margin-top: -40rpx;
}

.tip-text .highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.compare-section {
  margin-top: 40rpx;
}

.compare-title {
  text-align: center;
  font-size: 36rpx;
  color: var(--color-text-primary);
  margin-bottom: 32rpx;
  padding: 0 32rpx;
}

.compare-row {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx calc(230rpx + env(safe-area-inset-bottom));
}

.compare-card {
  flex: 1;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-correct {
  border: 3rpx solid var(--color-success);
}

.card-wrong {
  border: 3rpx solid var(--color-primary);
}

.card-image-wrapper {
  position: relative;
  overflow: hidden;
  height: 300rpx;
}

.phone-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.phone-correct {
  background: linear-gradient(180deg, #d4f5d9, #a8e6b3);
}

.phone-wrong {
  background: linear-gradient(180deg, #ffe0e3, #ffb3b8);
}

.phone-emoji {
  font-size: 120rpx;
  line-height: 1;
}

.phone-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.overlay-correct {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(40, 185, 64, 0.1), transparent);
}

.overlay-wrong {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(255, 43, 59, 0.1), transparent);
}

.card-bottom {
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.correct-bottom {
  background: var(--color-success-light);
  color: var(--color-success);
}

.wrong-bottom {
  background: var(--color-error-light);
  color: var(--color-primary);
}

.check-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.card-text {
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.bottom-actions {
  /* position: fixed; */
  /* bottom: calc(110rpx + env(safe-area-inset-bottom)); */
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.05);
  z-index: 50;
}

.action-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 0;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.secondary-btn {
  background: var(--color-background);
  color: var(--color-text-secondary);
}

.primary-btn {
  background: var(--color-primary-gradient);
  /* color: #fff; */
  box-shadow: 0 8rpx 24rpx rgba(255, 43, 59, 0.3);
}

.btn-icon-text {
  font-size: 32rpx;
  line-height: 1;
}

.result-section {
  margin: 24rpx 32rpx;
  background: var(--color-background-white);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.result-close {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  padding: 8rpx 16rpx;
}

.result-image-wrap {
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
  background: var(--color-background);
}

.result-image {
  width: 100%;
  height: 100%;
}

.matched-list {
  margin-top: 16rpx;
}

.matched-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.matched-item:last-child {
  border-bottom: none;
}

.matched-info {
  flex: 1;
}

.matched-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.matched-brand {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.matched-price {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  margin-right: 16rpx;
}

.matched-arrow {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}

.no-match {
  text-align: center;
  padding: 40rpx 0;
}

.no-match-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.no-match-text {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
  margin-bottom: 24rpx;
}

.no-match-action {
  display: inline-flex;
  padding: 16rpx 48rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.no-match-action.secondary {
  background: var(--color-background);
  color: var(--color-text-secondary);
}

.no-match-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.history-section {
  margin: 24rpx 32rpx;
  background: var(--color-background-white);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.history-clear-btn {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  padding: 4rpx 12rpx;
}

.history-list {
  margin-top: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
}

.history-item:last-child {
  border-bottom: none;
}

.history-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  object-fit: cover;
  background: var(--color-background);
  flex-shrink: 0;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.history-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-brand {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.history-price {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.history-delete {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  padding: 4rpx 12rpx;
  margin-top: 4rpx;
  line-height: 1;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
}

.history-empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.history-empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.history-view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border-top: 1rpx solid var(--color-border);
  margin-top: 16rpx;
}

.history-view-all-arrow {
  margin-left: 6rpx;
  font-size: 22rpx;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 60rpx 80rpx;
  text-align: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
