@import '/styles/design-tokens.wxss';

.page-container {
  background-color: var(--color-background-gray);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.main-red-section {
  background: var(--color-primary-gradient);
  padding: 60rpx 40rpx 160rpx;
  border-radius: 0 0 40% 40% / 0 0 12% 12%;
  position: relative;
}

.main-title {
  text-align: center;
  font-size: 72rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 48rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 4rpx;
}

.count-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 64rpx;
  backdrop-filter: blur(10rpx);
}

.count-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.count-item {
  flex: 1;
  text-align: center;
}

.count-item .num {
  display: block;
  text-align: center;
  font-size: 64rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.count-item .label {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.click-wrap {
  background: #fff;
  border-radius: 48rpx;
  padding: 96rpx 48rpx;
  position: relative;
  text-align: center;
  box-shadow: 0 16rpx 64rpx rgba(255, 43, 59, 0.2);
}

.click-wrap:active {
  transform: scale(0.98);
}

.corner-mark {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-primary);
}

.corner-tl {
  top: 40rpx;
  left: 40rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 16rpx 0 0 0;
}

.corner-tr {
  top: 40rpx;
  right: 40rpx;
  border-left: none;
  border-bottom: none;
  border-radius: 0 16rpx 0 0;
}

.corner-bl {
  bottom: 40rpx;
  left: 40rpx;
  border-right: none;
  border-top: none;
  border-radius: 0 0 0 16rpx;
}

.corner-br {
  bottom: 40rpx;
  right: 40rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 16rpx 0;
}

.click-circle {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffecee, #fff);
  border: 8rpx solid var(--color-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 16rpx 48rpx rgba(255, 43, 59, 0.3);
}

.camera-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.click-text {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.4;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.hand-icon {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  width: 200rpx;
  height: 200rpx;
}

.digital-tag {
  width: 144rpx;
  height: 144rpx;
  background: linear-gradient(145deg, #fff, #f0f0f0);
  border-radius: 50%;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -72rpx auto 0;
  font-size: 36rpx;
  font-weight: 800;
  z-index: 10;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tip-text {
  text-align: center;
  font-size: 32rpx;
  color: var(--color-text-secondary);
  padding: 64rpx 40rpx;
  line-height: 1.6;
  background: #fff;
  margin: 0 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
  margin-top: -40rpx;
}

.tip-text .highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.compare-section {
  margin-top: 48rpx;
}

.compare-title {
  text-align: center;
  font-size: 36rpx;
  color: var(--color-text-primary);
  margin-bottom: 32rpx;
  padding: 0 32rpx;
}

.compare-row {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx 240rpx;
}

.compare-card {
  flex: 1;
  border-radius: 32rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-correct {
  border: 3rpx solid var(--color-success);
}

.card-wrong {
  border: 3rpx solid var(--color-primary);
}

.card-image-wrapper {
  position: relative;
  overflow: hidden;
  height: 300rpx;
}

.phone-preview {
  width: 100%;
  height: 100%;
}

.overlay-correct {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(40, 185, 64, 0.1), transparent);
}

.overlay-wrong {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(255, 43, 59, 0.1), transparent);
}

.card-bottom {
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.correct-bottom {
  background: var(--color-success-light);
  color: var(--color-success);
}

.wrong-bottom {
  background: var(--color-error-light);
  color: var(--color-primary);
}

.check-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.card-text {
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 0;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.secondary-btn {
  background: var(--color-background);
  color: var(--color-text-secondary);
}

.primary-btn {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 43, 59, 0.3);
}
