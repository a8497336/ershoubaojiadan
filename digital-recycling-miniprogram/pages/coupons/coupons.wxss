@import '/styles/design-tokens.wxss';

.page-container { min-height: 100vh; background: var(--color-background); padding-bottom: 40rpx; }

.coupon-list { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }

.coupon-item {
  display: flex;
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.coupon-item:active { background: var(--card-active-bg); }
.coupon-left {
  width: 200rpx;
  background: var(--color-primary-gradient);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  color: var(--color-text-inverse);
}
.coupon-value { font-size: var(--font-size-xl); font-weight: var(--font-weight-bold); }
.coupon-cond { font-size: var(--font-size-xs); opacity: 0.8; margin-top: 6rpx; }
.coupon-right {
  flex: 1;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.coupon-title { font-size: var(--font-size-md); color: var(--color-text-primary); font-weight: var(--font-weight-medium); }
.coupon-date { font-size: var(--font-size-xs); color: var(--color-text-tertiary); margin-top: 8rpx; }

.error-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 600rpx; }
.error-img { width: 160rpx; height: 160rpx; margin-bottom: 24rpx; }
.error-title { font-size: var(--font-size-xl); color: var(--color-text-primary); font-weight: var(--font-weight-bold); margin-bottom: 12rpx; }
.error-desc { font-size: var(--font-size-base); color: var(--color-text-tertiary); }

.empty-wrap { padding: 80rpx 0; }
.load-more { display: flex; justify-content: center; padding: 32rpx; }
.no-more { text-align: center; padding: 32rpx; color: var(--color-text-tertiary); font-size: var(--font-size-xs); }
