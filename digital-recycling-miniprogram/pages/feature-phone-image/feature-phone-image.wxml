<view class="feature-phone-page">
  <!-- 头部：与 price-quote 风格一致的红色渐变 header -->
  <view class="header-section">
    <view class="header-meta">
      <text>浏览量：{{viewCount}}</text>
      <text>更新时间：{{updateTime}}</text>
    </view>
    <view class="header-quota">
      <block wx:if="{{!quotaLoaded}}">
        <text class="quota-text">加载中…</text>
      </block>
      <block wx:elif="{{isVip}}">
        <text class="quota-text vip">会员无限查看</text>
      </block>
      <block wx:else>
        <text class="quota-text">今日剩余：{{quoteDailyRemaining}} 次</text>
      </block>
    </view>
    <view class="header-title">{{title}}</view>
    <view class="header-rules">
      <text class="rules-title">回收标准释义：</text>
      <text>开机进系统/屏好/屏坏/不开机/废板 等机况定义说明...</text>
      <text>具体以实际检测为准，价格仅供参考</text>
    </view>
  </view>

  <!-- 图片区：替代原 price-table -->
  <view class="image-section">
    <block wx:if="{{accessGranted && image}}">
      <image class="feature-image" src="{{image}}" mode="widthFix" bindtap="previewImage"></image>
    </block>
    <block wx:elif="{{!accessGranted}}">
      <view class="image-empty">加载中…</view>
    </block>
    <block wx:else>
      <view class="image-empty">暂无可展示内容</view>
    </block>
  </view>

  <!-- 底部备注：与 price-quote 一致 -->
  <view class="footer-note">
    <text class="note-title">备注说明：</text>
    <text>1. 以上内容为对应机型回收参考，实际以到货检测为准</text>
    <text>2. 图片中价格与配置可能随市场行情调整，请以最新数据为准</text>
    <text>3. "/" 表示该机型此状态暂不回收或无报价</text>
    <text>4. 废板整机指主板损坏无法开机的完整机器</text>
    <text>5. 具体回收价格请咨询客服或参考最新报价单</text>
  </view>
</view>
