<view class="login-page">
  <view class="login-content">
    <view class="logo-wrap">
      <image class="logo-img" src="/images/icons/avatar.svg" mode="aspectFit"/>
    </view>

    <view class="welcome-text">
      <text class="welcome-title">欢迎使用联赢电子回收</text>
      <text class="welcome-desc">一键授权登录，享更多特权</text>
    </view>

    <view class="btn-group">
      <button class="login-btn" bindtap="handleLogin">
        微信一键登录
      </button>
      <view class="cancel-btn" bindtap="handleCancel">
        暂不登录
      </view>
    </view>
  </view>

  <view class="agreement-footer safe-area-bottom">
    <view class="agreement-check {{isAgreed ? 'checked' : ''}}" bindtap="onAgreementChange"></view>
    <text class="agreement-label">我已阅读并同意</text>
    <text class="agreement-link">《用户协议》</text>
    <text class="agreement-label">、</text>
    <text class="agreement-link">《隐私政策协议》</text>
  </view>
</view>