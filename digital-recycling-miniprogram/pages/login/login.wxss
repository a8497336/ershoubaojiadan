@import '../../styles/design-tokens.wxss';

.login-page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.logo-wrap {
  margin-bottom: 40rpx;
}

.logo-img {
  width: 120rpx;
  height: 120rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #999;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.btn-group {
  width: 100%;
  padding: 0 64rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #ff2d4a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 74, 0.3);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.9;
  background: #e62640;
}

.cancel-btn {
  margin-top: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 0;
}

.agreement-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.agreement-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  margin-right: 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.agreement-check.checked {
  background: #ff2d4a;
  border-color: #ff2d4a;
  position: relative;
}

.agreement-check.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 45%;
  transform: translate(-50%, -50%) rotate(-45deg);
  width: 10rpx;
  height: 18rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
}

.agreement-label {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #ff2d4a;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}