@import '../../styles/design-tokens.wxss';

.login-page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* ===== 自定义导航栏(navigationStyle: custom) ===== */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #ff2d4a;
  display: flex;
  align-items: center;
  height: auto;
  z-index: 1000;
}
.nav-back-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.nav-back-btn-hover {
  opacity: 0.6;
}
.nav-back-icon {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -6rpx;
}
.nav-title {
  flex: 1;
  text-align: center;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 500;
}
.nav-placeholder {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* padding-top 由 wxml 内联 style 提供:statusBarHeight + 44px */
  padding-top: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.logo-wrap {
  margin-bottom: 40rpx;
}

.logo-img {
  width: 120rpx;
  height: 120rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #999;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.btn-group {
  width: 100%;
  padding: 0 64rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #ff2d4a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 74, 0.3);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.9;
  background: #e62640;
}

.cancel-btn {
  margin-top: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 0;
}

.agreement-section {
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
  margin-top: 48rpx;
}

.agreement-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.agreement-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  margin-right: 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.agreement-check.checked {
  background: #ff2d4a;
  border-color: #ff2d4a;
  position: relative;
}

.agreement-check.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -60%) rotate(45deg);
  width: 10rpx;
  height: 18rpx;
  border-right: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
}

.agreement-label {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #ff2d4a;
}
.agreement-link:active {
  opacity: 0.6;
}
.agreement-link-hover {
  opacity: 0.6;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}