.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #fff5f6 0%, #ffffff 100%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: #ff2d4a;
  border-radius: 40rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 45, 74, 0.2);
}

.brand-name {
  margin-top: 32rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.slogan {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.login-btn-wrapper {
  width: 100%;
  margin-bottom: 48rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.login-btn.wechat-login {
  background: #07c160;
  color: #fff;
}

.login-btn.wechat-login:active {
  background: #06ad53;
}

.btn-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

.btn-text {
  letter-spacing: 2rpx;
}

.agreement-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.checkbox-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
}

.checkbox.checked {
  transform: scale(1.1);
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #ff2d4a;
  margin: 0 4rpx;
}

.login-footer {
  padding: 32rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #ccc;
}
