.bind-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.bind-header {
  text-align: center;
  padding: 40rpx 0 48rpx;
}

.header-icon {
  font-size: 96rpx;
  line-height: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-top: 20rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  padding: 0 40rpx;
  line-height: 1.5;
}

.bind-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #f7f7f7;
  border-radius: 14rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.code-input {
  flex: 1;
  height: 96rpx;
  font-size: 34rpx;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.input-placeholder {
  color: #bbb;
  font-size: 30rpx;
  letter-spacing: 0;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 24rpx;
  flex-shrink: 0;
}

.card-tip {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 20rpx;
}

.submit-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff2d4a, #ff6b6b);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 45, 74, 0.25);
}

.submit-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}

.reward-section {
  margin-top: 56rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
}

.reward-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.reward-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reward-item {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.reward-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff2d4a;
  margin-top: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.success-content {
  position: relative;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 56rpx 40rpx 40rpx;
  text-align: center;
  animation: popIn 0.3s ease;
}

@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 96rpx;
  line-height: 1;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-top: 20rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  line-height: 1.5;
}

.success-btn {
  margin-top: 40rpx;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #ff2d4a, #ff6b6b);
  color: #fff;
  font-size: 30rpx;
  border-radius: 42rpx;
  font-weight: 600;
}
