<view class="order-detail-page">
  <block wx:if="{{isLoading === false && order}}">
    <!-- 状态卡片 -->
    <view class="status-card">
      <view class="status-icon">
        {{order.statusInfo ? order.statusInfo.text : '处理中'}}
      </view>
      <view class="status-desc">
        <block wx:if="{{order.status === 'completed'}}">
          订单已完成，款项已打入您的钱包
        </block>
        <block wx:elif="{{order.status === 'inspecting'}}">
          商品正在质检中，请耐心等待
        </block>
        <block wx:elif="{{order.status === 'shipping' || order.status === 'pending'}}">
          订单已创建，请尽快发货
        </block>
        <block wx:elif="{{order.status === 'confirmed'}}">
          价格已确认，等待打款
        </block>
        <block wx:elif="{{order.status === 'cancelled'}}">
          订单已取消
        </block>
        <block wx:else>
          订单状态：{{order.statusInfo ? order.statusInfo.text : '处理中'}}
        </block>
      </view>
    </view>

    <!-- 订单流程时间轴 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">订单进度</text>
      </view>
      <view class="process-timeline">
        <view class="process-timeline-item {{item.completed ? 'completed' : ''}} {{item.active ? 'active' : ''}}" wx:for="{{orderProcessTimeline}}" wx:key="index">
          <view class="process-dot"></view>
          <view class="process-content">
            <text class="process-title">{{item.title}}</text>
            <text class="process-desc">{{item.desc}}</text>
            <text class="process-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 物流信息 -->
    <view class="section-card" wx:if="{{order.logistics && order.logistics.company}}">
      <view class="section-header">
        <text class="section-title">物流信息</text>
        <text class="section-action" bindtap="copyTrackingNo">复制单号</text>
      </view>
      <view class="logistics-info">
        <view class="logistics-row">
          <text class="logistics-label">快递公司</text>
          <text class="logistics-value">{{order.logistics.company}}</text>
        </view>
        <view class="logistics-row">
          <text class="logistics-label">运单号</text>
          <text class="logistics-value">{{order.logistics.trackingNo}}</text>
        </view>
        <view class="logistics-row">
          <text class="logistics-label">物流状态</text>
          <text class="logistics-value status">{{order.logistics.status}}</text>
        </view>
      </view>

      <!-- 物流时间轴 -->
      <view class="timeline-section" wx:if="{{order.logistics.timeline && order.logistics.timeline.length > 0}}">
        <view class="timeline-header" bindtap="toggleTimeline">
          <text>物流详情</text>
          <text class="timeline-toggle">{{timelineExpanded ? '收起' : '展开'}} ></text>
        </view>
        <view class="timeline" wx:if="{{timelineExpanded}}">
          <view class="timeline-item {{index === 0 ? 'active' : ''}}" wx:for="{{order.logistics.timeline}}" wx:key="index">
            <view class="timeline-dot"></view>
            <view class="timeline-content">
              <text class="timeline-desc">{{item.desc}}</text>
              <text class="timeline-time">{{item.time}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 商品清单 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">商品清单</text>
      </view>
      <view class="product-list">
        <view class="product-item" wx:for="{{order.items}}" wx:key="index">
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-condition">{{item.condition}}</text>
          </view>
          <view class="product-price">
            <text>¥{{item.price}}</text>
            <text class="product-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
      <view class="order-summary">
        <view class="summary-row">
          <text>商品总价</text>
          <text>¥{{order.totalAmountText}}</text>
        </view>
        <view class="summary-row total">
          <text>实收金额</text>
          <text class="total-price">¥{{order.totalAmountText}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">订单信息</text>
        <text class="section-action" bindtap="copyOrderNo">复制订单号</text>
      </view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">订单编号</text>
          <text class="info-value">{{order.order_no || order.id}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">创建时间</text>
          <text class="info-value">{{order.created_at || order.createTime}}</text>
        </view>
        <view class="info-row" wx:if="{{order.completed_at || order.completeTime}}">
          <text class="info-label">完成时间</text>
          <text class="info-value">{{order.completed_at || order.completeTime}}</text>
        </view>
        <view class="info-row" wx:if="{{order.cancelled_at || order.cancelTime}}">
          <text class="info-label">取消时间</text>
          <text class="info-value">{{order.cancelled_at || order.cancelTime}}</text>
        </view>
        <view class="info-row" wx:if="{{order.cancelReason}}">
          <text class="info-label">取消原因</text>
          <text class="info-value">{{order.cancelReason}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <button class="btn btn-outline" bindtap="contactService">联系客服</button>
      <button class="btn btn-primary" bindtap="goToHome">继续回收</button>
    </view>
  </block>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading === true}}">
    <view class="skeleton-detail">
      <view class="skeleton-line title"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line short"></view>
    </view>
  </view>
</view>