<view class="page-container">
  <view class="invite-header">
    <view class="invite-title">邀好友 分佣金</view>
    <view class="invite-desc">每成功邀请一位好友，即可获得佣金奖励</view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-value">{{inviteCount}}</view>
      <view class="stat-label">邀请人数</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">¥{{totalReward}}</view>
      <view class="stat-label">累计奖励</view>
    </view>
  </view>

  <view class="invite-code-section">
    <view class="code-label">我的邀请码</view>
    <view class="code-value">{{inviteCode || '暂无'}}</view>
    <view class="code-actions">
      <view class="action-btn copy-btn" bindtap="handleCopyCode">复制邀请码</view>
      <view class="action-btn share-btn" bindtap="handleShare">分享给好友</view>
    </view>
  </view>

  <view class="rules-section">
    <view class="rules-title">邀请规则</view>
    <view class="rule-item">1、分享邀请码或链接给好友</view>
    <view class="rule-item">2、好友通过邀请码注册成功</view>
    <view class="rule-item">3、好友完成首次回收交易</view>
    <view class="rule-item">4、您即可获得相应佣金奖励</view>
    <view class="rule-item">5、佣金可提现至微信零钱</view>
  </view>
</view>
