<view class="page-container">
  <block wx:if="{{loading}}">
    <view class="skeleton-wrap">
      <view class="skeleton-header"></view>
      <view class="skeleton-card"></view>
      <view class="skeleton-section"></view>
    </view>
  </block>

  <block wx:elif="{{networkError}}">
    <view class="error-state" bindtap="retryLoad">
      <image class="error-image" src="/images/icons/empty.svg" mode="aspectFit" />
      <text class="error-text">网络连接失败，点击重新加载</text>
      <view class="retry-btn">重新加载</view>
    </view>
  </block>

  <block wx:else>

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-icon-wrap">
          <text class="stat-icon">👥</text>
        </view>
        <view class="stat-value">{{inviteCount}}</view>
        <view class="stat-label">成功邀请</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-wrap">
          <text class="stat-icon">🎁</text>
        </view>
        <view class="stat-value">{{totalReward}}</view>
        <view class="stat-label">累计奖励次数</view>
      </view>
    </view>

    <!-- 邀请码 + 二维码区域 -->
    <view class="code-section">
      <view class="code-card">
        <view class="code-card-left">
          <view class="code-label">我的邀请码</view>
          <view class="code-value">{{inviteCode || '暂无'}}</view>
          <view class="code-copy" bindtap="handleCopyCode">
            <text class="code-copy-icon">📋</text>
            <text>复制邀请码</text>
          </view>
        </view>
        <view class="code-card-right">
          <image wx:if="{{qrCodeUrl}}" class="qr-image" src="{{qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress />
          <view wx:else class="qr-placeholder">
            <text class="qr-placeholder-icon">📷</text>
            <text class="qr-placeholder-text">加载中</text>
          </view>
        </view>
      </view>
      <view class="code-tip">长按二维码或截图保存，好友扫码即可加入</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="action-btn share-btn" open-type="share">
        <text class="action-btn-icon">💬</text>
        <text>分享好友</text>
      </button>
      <view class="action-btn poster-btn" bindtap="handleSavePoster">
        <text class="action-btn-icon">{{posterLoading ? '⏳' : '🖼️'}}</text>
        <text>{{posterLoading ? '生成中...' : '保存海报'}}</text>
      </view>
    </view>

    <!-- 最近邀请记录 -->
    <view class="records-section" wx:if="{{inviteList.length > 0}}">
      <view class="section-header">
        <text class="section-title">最近邀请</text>
        <text class="section-count">共 {{inviteCount}} 人</text>
      </view>
      <view wx:for="{{inviteList}}" wx:key="id" class="record-item">
        <image class="record-avatar" src="{{item.invitee.avatar || '/images/icons/avatar.svg'}}" mode="aspectFill" />
        <view class="record-info">
          <text class="record-name">{{item.invitee.nickname || '微信用户'}}</text>
          <text class="record-time">{{item.createdAt}}</text>
        </view>
        <view class="record-reward">
          <text class="record-reward-value">+{{item.grantedTimes}}</text>
          <text class="record-reward-label">次报价</text>
        </view>
      </view>
    </view>

    <!-- 邀请规则 -->
    <view class="rules-section">
      <view class="section-header">
        <text class="section-title">邀请规则</text>
      </view>
      <view class="rule-list">
        <view class="rule-item">
          <view class="rule-num">1</view>
          <text>点击「分享好友」或「保存海报」发送给好友</text>
        </view>
        <view class="rule-item">
          <view class="rule-num">2</view>
          <text>好友通过邀请链接/海报进入并完成微信登录注册</text>
        </view>
        <view class="rule-item">
          <view class="rule-num">3</view>
          <text>新用户注册后邀请立即生效，奖励自动发放</text>
        </view>
        <view class="rule-item">
          <view class="rule-num">4</view>
          <text>老用户点击邀请链接无效，无法重复获得奖励</text>
        </view>
        <view class="rule-item">
          <view class="rule-num">5</view>
          <text>奖励次数可用于查看报价单，以后台配置为准</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 海报预览弹窗 -->
  <view class="poster-modal" wx:if="{{showPosterModal}}" catchtouchmove="noop">
    <view class="poster-mask" bindtap="closePosterModal"></view>
    <view class="poster-close" bindtap="closePosterModal">✕</view>
    <view class="poster-content">
      <canvas type="2d" id="posterCanvas" class="poster-canvas" style="width: 375px; height: 667px;" bindtap="onCanvasTap"></canvas>
      <view class="poster-actions">
        <view class="poster-save-btn" bindtap="doSavePoster">保存到相册</view>
      </view>
    </view>
  </view>
</view>