@import '/styles/design-tokens.wxss';

.brand-page {
  background: #f5f5f5;
  height: 87vh;
  padding-bottom: 120rpx;
  overflow: hidden;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  background: #ff2d4a;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  position: sticky;
  z-index: 100;
}
.nav-bar .back-btn {
  color: #fff;
  font-size: 32rpx;
  position: absolute;
  left: 24rpx;
}
.nav-bar .title-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}

/* ===== 搜索栏 ===== */
.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #fff;
}
.search-input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #eee;
}
.search-input-box .s-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}
.search-input-box input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  background: transparent;
}
.search-btn {
  background: #ff2d4a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
}
.search-btn:active { background: #e62540; }

/* ===== 分类Tab ===== */
.category-tabs {
  display: flex;
  background: #fff;
  padding: 0 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.category-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.category-tab.active {
  color: #ff2d4a;
  font-weight: 600;
}
.category-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: #ff2d4a;
  border-radius: 4rpx;
}

/* ===== 双栏布局 ===== */
.content-row {
  display: flex;
  height: calc(100vh - 336rpx);
}

/* ===== 品牌侧边栏 ===== */
.brand-sidebar {
  width: 160rpx;
  background: #f8f8f8;
  
  padding-bottom: 400rpx;
}
.brand-scroll { height: 100%; }

.brand-sidebar-item {
  padding: 28rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  transition: background 0.2s;
}
.brand-sidebar-item:active { background: #e9e9e9; }
.brand-sidebar-item.active {
  background: #fff;
  color: #ff2d4a;
  font-weight: 600;
  border-left: 6rpx solid #ff2d4a;
}

/* ===== 产品列表 ===== */
.product-list-area {
  flex: 1;
  background: #fff;
  padding-bottom: 350rpx;
}
.product-scroll { height: 100%; padding: 0 12rpx; padding-bottom: 250rpx; }

.group-title {
  font-size: 28rpx;
  color: #ff2d4a;
  font-weight: 600;
  padding: 20rpx 0 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.group-title::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background: #ff2d4a;
  border-radius: 3rpx;
}

.product-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 12rpx;
  padding-right: 30px;
  border-bottom: 1rpx solid #f5f5f5;
}
.product-card:active { background: #f9f9f9; }

.product-image-area {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.product-image-area image {
  width: 100%;
  height: 100%;
}
.product-placeholder {
  font-size: 36rpx;
}

.product-info { flex: 1; }
.product-info .p-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.product-info .p-note {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.product-price {
  font-size: 32rpx;
  color: #ff2d4a;
  font-weight: bold;
  margin-left: 24rpx;
}

.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 32rpx 0;
}

/* ===== 浮动回收车按钮 ===== */
.floating-cart {
  position: fixed;
  bottom: 160rpx;
  right: 24rpx;
  width: 100rpx;
  height: 100rpx;
  background: #ff2d4a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255,45,74,0.4);
  z-index: 99;
  font-size: 44rpx;
  color: #fff;
}
.floating-cart:active { background: #e62540; }

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #fff;
  color: #ff2d4a;
  font-size: 22rpx;
  font-weight: bold;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ff2d4a;
}

/* ===== 产品详情弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.modal-panel {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx 24rpx calc(200rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
  max-height: 70%;
  display: flex;
  flex-direction: column;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  height: 50rpx;
}
.contant {
  flex: 1;
  overflow: scroll;
}
.button-list {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #333; }
.modal-close { font-size: 40rpx; color: #999; padding: 8rpx; }

.modal-image-area {
  width: 100%;
  aspect-ratio: 4 / 3;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 100rpx;
}
.modal-image-area image { width: 100%; height: 100%; border-radius: 16rpx; }

.trend-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border: 2rpx solid #ff2d4a;
  border-radius: 48rpx;
  color: #ff2d4a;
  font-size: 28rpx;
  font-weight: 500;
}
.trend-btn:active {
  background: #fff5f6;
}

.condition-section { margin-bottom: 24rpx; }
.condition-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.condition-list {  overflow-y: auto; }
.condition-empty { display: flex; justify-content: center; padding: 32rpx 0; }

.condition-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.condition-price-row:last-child { border-bottom: none; }

.condition-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  min-width: 0;
}

.condition-price {
  font-size: 30rpx;
  color: #ff2d4a;
  font-weight: bold;
  margin: 0 24rpx;
  min-width: 100rpx;
  text-align: right;
}
.condition-price.zero {
  color: #ccc;
  font-weight: normal;
}

.condition-qty-ctrl {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  background: #fff;
}
.qty-btn:active { background: #f0f0f0; }
.qty-btn.disabled { opacity: 0.3; }

.qty-num { font-size: 36rpx; color: #333; font-weight: 600; min-width: 60rpx; text-align: center; }

.add-cart-btn {
  width: 45%;
  background: #ff2d4a;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 10rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}
.close-cart-btn {
  width: 45%;
  color: red;
  border: none;
  border-radius: 48rpx;
  padding: 10rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  border: 1px solid red;
}
.add-cart-btn:active { background: #e62540; }

/* ===== 搜索结果层级标题 ===== */
.search-category-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
  padding: 24rpx 12rpx 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.search-category-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: #ff2d4a;
  border-radius: 4rpx;
}

.search-brand-title {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  padding: 16rpx 20rpx 6rpx;
  color: #ff2d4a;
}

/* 全屏加载 */
.full-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}

/* 响应式调整 - 匹配H5端的媒体查询 */
@media (max-width: 375px) {
  .nav-bar {
    min-height: 80rpx;
  }
  .nav-bar .title-text {
    font-size: 32rpx;
  }
  .search-section {
    padding: 16rpx 20rpx;
    gap: 12rpx;
  }
  .search-input-box {
    padding: 14rpx 24rpx;
  }
  .search-btn {
    padding: 14rpx 28rpx;
    font-size: 26rpx;
  }
  .category-tabs {
    padding: 0 10rpx;
  }
  .category-tab {
    padding: 20rpx 0;
    font-size: 26rpx;
  }
  .content-row {
    height: calc(100vh - 320rpx);
  }
  .brand-sidebar {
    width: 140rpx;
  }
  .brand-sidebar-item {
    padding: 24rpx 12rpx;
    font-size: 24rpx;
  }
  .group-title {
    font-size: 26rpx;
    padding: 16rpx 0 6rpx;
  }
  .product-card {
    padding: 20rpx 10rpx;
  }
  .product-info .p-name {
    font-size: 26rpx;
  }
  .product-info .p-note {
    font-size: 20rpx;
  }
  .product-price {
    font-size: 28rpx;
    margin-left: 20rpx;
  }
  .floating-cart {
    bottom: 140rpx;
    right: 20rpx;
    width: 88rpx;
    height: 88rpx;
    font-size: 40rpx;
  }
  .cart-badge {
    font-size: 20rpx;
    min-width: 32rpx;
    height: 32rpx;
  }
  .modal-panel {
    padding: 28rpx 20rpx 40rpx;
  }
  .modal-title {
    font-size: 30rpx;
    margin-bottom: 36rpx;
  }
  .condition-label {
    font-size: 24rpx;
  }
  .condition-name {
    font-size: 26rpx;
  }
  .condition-price {
    font-size: 28rpx;
    margin: 0 20rpx;
  }
  .condition-qty-ctrl {
    gap: 16rpx;
  }
  .qty-btn {
    width: 52rpx;
    height: 52rpx;
    font-size: 30rpx;
  }
  .qty-num {
    font-size: 32rpx;
    min-width: 56rpx;
  }
  .add-cart-btn {
    padding: 24rpx 0;
    font-size: 30rpx;
  }
}

@media (max-width: 320px) {
  .nav-bar {
    min-height: 72rpx;
  }
  .nav-bar .title-text {
    font-size: 30rpx;
  }
  .search-section {
    padding: 12rpx 16rpx;
    gap: 10rpx;
  }
  .search-input-box {
    padding: 12rpx 20rpx;
  }
  .search-btn {
    padding: 12rpx 24rpx;
    font-size: 24rpx;
  }
  .category-tabs {
    padding: 0 8rpx;
  }
  .category-tab {
    padding: 18rpx 0;
    font-size: 24rpx;
  }
  .content-row {
    height: calc(100vh - 300rpx);
  }
  .brand-sidebar {
    width: 120rpx;
  }
  .brand-sidebar-item {
    padding: 20rpx 10rpx;
    font-size: 22rpx;
  }
  .group-title {
    font-size: 24rpx;
    padding: 14rpx 0 6rpx;
  }
  .product-card {
    padding: 16rpx 8rpx;
  }
  .product-info .p-name {
    font-size: 24rpx;
  }
  .product-info .p-note {
    font-size: 18rpx;
  }
  .product-price {
    font-size: 26rpx;
    margin-left: 16rpx;
  }
  .floating-cart {
    bottom: 130rpx;
    right: 16rpx;
    width: 80rpx;
    height: 80rpx;
    font-size: 36rpx;
  }
  .cart-badge {
    font-size: 18rpx;
    min-width: 28rpx;
    height: 28rpx;
  }
  .modal-panel {
    padding: 24rpx 16rpx 32rpx;
  }
  .modal-title {
    font-size: 28rpx;
    margin-bottom: 32rpx;
  }
  .condition-label {
    font-size: 22rpx;
  }
  .condition-name {
    font-size: 24rpx;
  }
  .condition-price {
    font-size: 26rpx;
    margin: 0 16rpx;
  }
  .condition-qty-ctrl {
    gap: 12rpx;
  }
  .qty-btn {
    width: 48rpx;
    height: 48rpx;
    font-size: 28rpx;
  }
  .qty-num {
    font-size: 28rpx;
    min-width: 48rpx;
  }
  .add-cart-btn {
    padding: 20rpx 0;
    font-size: 28rpx;
  }

}
