@import '/styles/design-tokens.wxss';

.brand-list-container {
  background-color: var(--color-background);
  color: var(--color-text-primary);
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-section {
  background: var(--color-background-white);
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-btn:active {
  opacity: 0.6;
}

.back-arrow {
  font-size: 48rpx;
  color: var(--color-text-primary);
  font-weight: 300;
  line-height: 1;
}

.search-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  white-space: nowrap;
}

.search-box {
  flex: 1;
  height: 72rpx;
  background: var(--color-background);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  gap: 12rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
}

.search-box input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.category-tabs {
  height: 88rpx;
  background: var(--color-background-white);
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  gap: 40rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  white-space: nowrap;
}

.category-tab {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  position: relative;
  padding-bottom: 16rpx;
  display: inline-block;
}

.category-tab.active {
  color: var(--color-text-primary);
  font-weight: 600;
}

.category-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.brand-sidebar {
  width: 170rpx;
  background: var(--color-background-gray);
  height: 100%;
}

.brand-item {
  padding: 28rpx 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  position: relative;
  line-height: 1.3;
}

.brand-item.active {
  background: var(--color-background-white);
  color: var(--color-primary);
  font-weight: 600;
}

.brand-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: var(--color-primary);
  border-radius: 0 4rpx 4rpx 0;
}

.product-list {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
  background: var(--color-background-white);
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

/* 分组区域 */
.group-section {
  margin-bottom: 16rpx;
}

.quick-order-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.quick-order-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.quick-order-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-primary);
  font-size: 26rpx;
  border: 1rpx solid var(--color-primary);
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
}

.btn-arrow {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.group-title {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 600;
  padding: 28rpx 0 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: relative;
  padding-left: 20rpx;
}

.group-title::before {
  content: '';
  position: absolute;
  left: 0;
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

.product-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 20rpx;
  border-bottom: 1rpx solid var(--color-background);
  transition: background-color 0.2s ease;
}

.product-item:active {
  background-color: #fafafa;
}

.product-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.product-dot {
  width: 12rpx;
  height: 12rpx;
  background: #ddd;
  border-radius: 50%;
  flex-shrink: 0;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price-section {
  text-align: right;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.product-price {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 600;
  display: block;
}

.product-price.price-inquiry {
  color: #999;
  font-size: 28rpx;
  font-weight: normal;
}

.product-price-tag {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.floating-cart {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 112rpx;
  height: 112rpx;
  background: var(--color-background-white);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 90;
}

.cart-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.cart-icon image {
  width: 100%;
  height: 100%;
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  font-weight: 600;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-background-white);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
  display: flex;
  flex-direction: column;
}

.modal-overlay.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  position: relative;
  border-bottom: 1rpx solid var(--color-background);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.modal-close {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close::before,
.modal-close::after {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 4rpx;
  background: var(--color-text-tertiary);
}

.modal-close::before {
  transform: rotate(45deg);
}

.modal-close::after {
  transform: rotate(-45deg);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 30rpx;
}

.modal-image-placeholder {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin: 30rpx 0;
  background: var(--color-background);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.grade-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.grade-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.grade-info-icon {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--color-primary);
}

.history-price {
  font-size: 26rpx;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.quantity-section {
  margin-bottom: 40rpx;
}

.quantity-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quantity-section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

.quantity-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-background);
}

.quantity-info {
  flex: 1;
}

.quantity-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.quantity-help {
  width: 28rpx;
  height: 28rpx;
  border: 1rpx solid var(--color-text-placeholder);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.quantity-price {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.price-highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.modal-qty-control {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
  overflow: hidden;
}

.modal-qty-btn {
  width: 72rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-background-white);
  border: none;
  font-size: 36rpx;
  color: var(--color-text-secondary);
  padding: 0;
  margin: 0;
  line-height: 1;
}

.modal-qty-btn.minus {
  border-right: 1rpx solid var(--color-border);
}

.modal-qty-btn.plus {
  border-left: 1rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.modal-qty-input {
  width: 100rpx;
  height: 64rpx;
  text-align: center;
  border: none;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: var(--color-background-white);
}

.modal-footer {
  padding: 20rpx 30rpx 40rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid var(--color-background);
  background: var(--color-background-white);
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.modal-btn-outline {
  background: var(--color-background-white);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

.modal-btn-primary {
  background: var(--color-primary);
  color: #fff;
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 9999;
}
