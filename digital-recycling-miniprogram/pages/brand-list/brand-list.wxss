@import '/styles/design-tokens.wxss';

.brand-page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  background: #ff2d4a;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-bar .back-btn {
  color: #fff;
  font-size: 32rpx;
  position: absolute;
  left: 24rpx;
}
.nav-bar .title-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}

/* ===== 搜索栏 ===== */
.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #fff;
}
.search-input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #eee;
}
.search-input-box .s-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}
.search-input-box input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  background: transparent;
}
.search-btn {
  background: #ff2d4a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
}
.search-btn:active { background: #e62540; }

/* ===== 分类Tab ===== */
.category-tabs {
  display: flex;
  background: #fff;
  padding: 0 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.category-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.category-tab.active {
  color: #ff2d4a;
  font-weight: 600;
}
.category-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: #ff2d4a;
  border-radius: 4rpx;
}

/* ===== 双栏布局 ===== */
.content-row {
  display: flex;
  height: calc(100vh - 336rpx);
}

/* ===== 品牌侧边栏 ===== */
.brand-sidebar {
  width: 160rpx;
  background: #f8f8f8;
}
.brand-scroll { height: 100%; }

.brand-sidebar-item {
  padding: 28rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  transition: background 0.2s;
}
.brand-sidebar-item:active { background: #e9e9e9; }
.brand-sidebar-item.active {
  background: #fff;
  color: #ff2d4a;
  font-weight: 600;
  border-left: 6rpx solid #ff2d4a;
}

/* ===== 产品列表 ===== */
.product-list-area {
  flex: 1;
  background: #fff;
}
.product-scroll { height: 100%; padding: 0 12rpx; }

.group-title {
  font-size: 28rpx;
  color: #ff2d4a;
  font-weight: 600;
  padding: 20rpx 0 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.group-title::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background: #ff2d4a;
  border-radius: 3rpx;
}

.product-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.product-card:active { background: #f9f9f9; }

.product-info { flex: 1; }
.product-info .p-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.product-info .p-note {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.product-price {
  font-size: 32rpx;
  color: #ff2d4a;
  font-weight: bold;
  margin-left: 24rpx;
}

/* ===== 浮动回收车按钮 ===== */
.floating-cart {
  position: fixed;
  bottom: 160rpx;
  right: 24rpx;
  width: 100rpx;
  height: 100rpx;
  background: #ff2d4a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255,45,74,0.4);
  z-index: 99;
  font-size: 44rpx;
  color: #fff;
}
.floating-cart:active { background: #e62540; }

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #fff;
  color: #ff2d4a;
  font-size: 22rpx;
  font-weight: bold;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ff2d4a;
}

/* ===== 产品详情弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.modal-panel {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx 24rpx 48rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #333; }
.modal-close { font-size: 40rpx; color: #999; padding: 8rpx; }

.modal-image-area {
  width: 100%;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 100rpx;
}
.modal-image-area image { width: 100%; height: 100%; border-radius: 16rpx; }

/* 成色选择 */
.grade-bar { margin-bottom: 24rpx; }
.grade-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.grade-options { display: flex; gap: 16rpx; flex-wrap: wrap; }

.grade-item {
  padding: 12rpx 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
}
.grade-item:active { background: #f5f5f5; }
.grade-item.selected {
  border-color: #ff2d4a;
  color: #ff2d4a;
  background: #fff5f5;
}

/* 数量控制 */
.qty-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.qty-row .qty-label { font-size: 28rpx; color: #333; }

.qty-ctrl { display: flex; align-items: center; gap: 32rpx; }

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  background: #fff;
}
.qty-btn:active { background: #f0f0f0; }
.qty-btn.disabled { opacity: 0.3; }

.qty-num { font-size: 36rpx; color: #333; font-weight: 600; min-width: 60rpx; text-align: center; }

.add-cart-btn {
  width: 100%;
  background: #ff2d4a;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}
.add-cart-btn:active { background: #e62540; }

/* 全屏加载 */
.full-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}
