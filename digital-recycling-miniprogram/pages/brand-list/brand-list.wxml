<view class="brand-page">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">←</view>
    <view class="title-text">品牌列表</view>
  </view>

  <view wx:if="{{loading}}" class="full-loading">
    <loading-spinner size="medium" color="primary" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="search-section">
      <view class="search-input-box">
        <text class="s-icon">🔍</text>
        <input type="text" placeholder="搜索品牌产品" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="doSearch" />
      </view>
      <button class="search-btn" bindtap="doSearch">搜索</button>
    </view>

    <view class="category-tabs" wx:if="{{categories.length > 0}}">
      <view class="category-tab {{index === currentCategoryIndex ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-index="{{index}}">
        {{item.name}}
      </view>
    </view>

    <view wx:if="{{brands.length > 0 || productGroups.length > 0}}" class="content-row">
      <view class="brand-sidebar">
        <scroll-view class="brand-scroll" scroll-y enhanced show-scrollbar="{{false}}">
          <view class="brand-sidebar-item {{item.id === selectedBrandId ? 'active' : ''}}" wx:for="{{brands}}" wx:key="id" bindtap="selectBrand" data-id="{{item.id}}">{{item.name}}</view>
          <empty-state wx:if="{{brands.length === 0}}" text="暂无品牌" />
        </scroll-view>
      </view>

      <view class="product-list-area">
        <scroll-view class="product-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="loadMoreProducts">
          <block wx:for="{{productGroups}}" wx:key="title">
            <view class="group-title">{{item.title}}</view>
            <view class="product-card" wx:for="{{item.products}}" wx:for-item="product" wx:key="id" bindtap="openProductDetail" data-item="{{product}}">
              <view class="product-info">
                <view class="p-name">{{product.model || product.name}}</view>
              </view>
              <view class="product-price">{{product.highestPriceText}}</view>
            </view>
          </block>
          <empty-state wx:if="{{productGroups.length === 0 && !productsLoading}}" text="暂无产品，请先选择品牌" />
          <loading-spinner wx:if="{{productsLoading}}" size="small" color="gray" />
        </scroll-view>
      </view>
    </view>

    <empty-state wx:else text="暂无数据" />

    <view class="floating-cart" bindtap="goToCart" wx:if="{{cartCount > 0}}">
      <text>🛒</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount > 99 ? '99+' : cartCount}}</view>
    </view>

    <view class="modal-overlay" wx:if="{{showModal}}" bindtap="closeModal">
      <view class="modal-panel" catchtap="nop">
        <view class="modal-header">
          <view class="modal-title">{{selectedProduct.model || selectedProduct.name || '产品详情'}}</view>
          <view class="modal-close" bindtap="closeModal">×</view>
        </view>
        <view class="modal-image-area">
          <image wx:if="{{selectedProduct.image}}" src="{{selectedProduct.image}}" mode="aspectFit" />
          <text wx:else>📱</text>
        </view>
        <view class="trend-btn" bindtap="goToPriceTrend">📈 价格趋势</view>
        <view class="condition-section">
          <view class="condition-label">成色价格</view>
          <loading-spinner wx:if="{{conditionsLoading}}" size="small" color="gray" />
          <block wx:elif="{{conditions.length > 0}}">
            <view class="condition-list">
              <view class="condition-price-row" wx:for="{{conditions}}" wx:key="conditionId">
                <view class="condition-name">{{item.conditionName}}</view>
                <view class="condition-price {{item.price > 0 ? '' : 'zero'}}">{{item.priceText}}</view>
                <view class="condition-qty-ctrl">
                  <view class="qty-btn {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseConditionQty" data-index="{{index}}">−</view>
                  <text class="qty-num">{{item.quantity}}</text>
                  <view class="qty-btn" bindtap="increaseConditionQty" data-index="{{index}}">+</view>
                </view>
              </view>
            </view>
          </block>
          <view class="condition-empty" wx:else>暂无成色信息</view>
        </view>
        <button class="add-cart-btn" bindtap="addToCart">加入回收车</button>
      </view>
    </view>
  </block>

  <custom-tabbar activeTab="priceList" />
</view>
