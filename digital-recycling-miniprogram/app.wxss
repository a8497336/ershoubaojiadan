@import '/styles/design-tokens.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--color-background);
  color: var(--color-text-primary);
  font-size: var(--font-size-base);
  line-height: var(--line-height-normal);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ========== 通用容器 ========== */
.container {
  padding-bottom: 120rpx;
}

.page-container {
  min-height: 100vh;
  background: var(--color-background);
  padding-bottom: 200rpx;
}

/* ========== 按钮系统 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  border: none;
  transition: all var(--transition-fast);
  line-height: 1;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  box-shadow: var(--shadow-primary);
}

.btn-primary:active {
  background: var(--color-primary-dark);
  transform: scale(0.98);
}

.btn-primary:disabled {
  background: var(--color-text-disabled, #ccc);
  box-shadow: none;
}

.btn-secondary {
  background: var(--color-primary-light);
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-outline:active {
  background: var(--color-primary-light);
}

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
}

.btn-block {
  width: 100%;
}

.btn-sm {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: var(--font-size-sm);
}

.btn-lg {
  height: 104rpx;
  padding: 0 64rpx;
  font-size: var(--font-size-lg);
}

/* ========== 卡片系统 ========== */
.card {
  background: var(--color-background-white);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.card-hover {
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.card-hover:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

/* ========== 输入框系统 ========== */
.input-group {
  display: flex;
  align-items: center;
  background: var(--color-background-gray);
  border-radius: var(--radius-full);
  padding: 0 var(--space-3);
  height: 80rpx;
}

.input-group input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  margin-left: var(--space-2);
}

.input-group .input-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== 标签系统 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.tag-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-success {
  background: var(--color-success-light);
  color: var(--color-success);
}

.tag-warning {
  background: var(--color-warning-light);
  color: var(--color-warning);
}

/* ========== 价格显示 ========== */
.price {
  font-weight: var(--font-weight-bold);
}

.price-high { color: var(--color-price-high); }
.price-mid { color: var(--color-price-mid); }
.price-low { color: var(--color-price-low); }

/* ========== 角标 ========== */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-size-xs);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: var(--font-weight-bold);
}

.badge-dot {
  min-width: 16rpx;
  width: 16rpx;
  height: 16rpx;
  padding: 0;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--space-3) 0;
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 品牌颜色（保留兼容） ========== */
.bg-huawei { background: #cf0a2c; }
.bg-vivo { background: #415fff; }
.bg-oppo { background: #009b4d; }
.bg-realme { background: #ffc915; color: #333 !important; }
.bg-xiaomi { background: #ff6900; }
.bg-apple { background: #555; }
.bg-samsung { background: #1428a0; }
.bg-oneplus { background: #f50514; }
.bg-nokia { background: #124191; }
.bg-meitu { background: #ff4d94; }
.bg-meizu { background: #00b4ff; }
.bg-nubia { background: #1a1a1a; }
.bg-360 { background: #4caf50; }
.bg-smartisan { background: #e02e24; }
.bg-zte { background: #00a0e9; }
.bg-coolpad { background: #00b0f0; }
.bg-lenovo { background: #e2231a; }
.bg-htc { background: #8bc34a; }
.bg-blackberry { background: #000; }
.bg-hisense { background: #00a0e9; }
.bg-doov { background: #e91e63; }
.bg-gree { background: #ff0000; }
.bg-moto { background: #000; }
.bg-asus { background: #00539b; }
.bg-royole { background: #ff6b00; }
.bg-google { background: #4285f4; }
.bg-jinli { background: #e66b1a; }
.bg-8848 { background: #1a1a1a; }
.bg-sugar { background: #ff6b6b; }
.bg-bbk { background: #ff2d4a; }
.bg-leeco { background: #2196f3; }
.bg-tcl { background: #ff0000; }
.bg-chinamobile { background: #0099cc; }

/* ========== 动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.animate-fade-in {
  animation: fadeIn var(--transition-normal) ease;
}

.animate-slide-up {
  animation: slideUp var(--transition-normal) ease;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm, 8rpx);
  border: 2rpx solid var(--color-border, #e0e0e0);
  background: var(--color-background-white, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg, 36rpx);
  color: var(--color-text-primary, #333);
  line-height: 1;
}

.qty-btn:active {
  background: var(--color-background-gray, #f5f5f5);
}

.qty-input {
  width: 72rpx;
  height: 56rpx;
  text-align: center;
  font-size: var(--font-size-sm, 26rpx);
  border: 2rpx solid var(--color-border, #e0e0e0);
  border-radius: var(--radius-sm, 8rpx);
  background: var(--color-background-white, #fff);
}
