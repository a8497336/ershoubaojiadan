/* pages/index/index.wxss - 定位测试 Demo 样式 */

.page {
  padding: 24rpx 24rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff2d4a;
  line-height: 1.4;
}

.card-content {
  font-size: 26rpx;
  color: #555;
  word-break: break-all;
  line-height: 1.6;
}

.card-content.mono {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  background-color: #f8f8f8;
  padding: 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
  font-size: 24rpx;
}

.status-success {
  color: #28b940 !important;
  font-weight: 600;
}

.status-error {
  color: #ff2d4a !important;
  font-weight: 600;
}

/* 按钮 */
.btn {
  display: block;
  width: 100%;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  line-height: 1.5;
}

.btn::after {
  border: none;
}

.btn-primary {
  background-color: #ff2d4a;
  color: #fff;
}

.btn-secondary {
  background-color: #fff0f0;
  color: #ff2d4a;
  border: 2rpx solid #ff2d4a;
}

.btn-ghost {
  background-color: #f5f5f5;
  color: #666;
}

.btn-hover {
  opacity: 0.75;
  transform: scale(0.98);
}

.hint {
  font-size: 22rpx;
  color: #999;
  margin: -8rpx 0 16rpx 8rpx;
}

/* 日志区 */
.log-list {
  background-color: #1e1e1e;
  border-radius: 8rpx;
  padding: 16rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.log-empty {
  color: #888;
  font-size: 24rpx;
  text-align: center;
  padding: 20rpx 0;
}

.log-item {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
  padding: 4rpx 0;
  white-space: pre-wrap;
}

.log-info {
  color: #d4d4d4;
}

.log-warn {
  color: #dcdcaa;
}

.log-error {
  color: #f48771;
  font-weight: 500;
}

/* API 兼容性区 */
.api-check {
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #eee;
}

.api-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx dashed #eee;
  font-size: 24rpx;
}

.api-row:last-child {
  border-bottom: none;
}

.api-name {
  font-family: 'SFMono-Regular', Consolas, monospace;
  color: #333;
  font-weight: 500;
}

.api-status {
  color: #999;
  font-size: 22rpx;
}

/* 底部卡片 */
.footer-card {
  margin-bottom: 0;
}